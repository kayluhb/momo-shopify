[
  {
    "name": "theme_info",
    "theme_name": "Momo",
    "theme_version": "0.1.0",
    "theme_author": "Caleb Brown",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      },
      {
        "type": "range",
        "id": "min_page_margin_mobile",
        "min": 8,
        "max": 40,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin_mobile",
        "default": 12
      },
      {
        "type": "header",
        "content": "t:labels.grid_spacing_header"
      },
      {
        "type": "range",
        "id": "grid_gap",
        "min": 0,
        "max": 48,
        "step": 2,
        "unit": "px",
        "label": "t:labels.grid_gap",
        "default": 12
      },
      {
        "type": "range",
        "id": "grid_gap_mobile",
        "min": 0,
        "max": 48,
        "step": 2,
        "unit": "px",
        "label": "t:labels.grid_gap_mobile",
        "default": 12
      },
      {
        "type": "header",
        "content": "t:labels.section_spacing_header"
      },
      {
        "type": "range",
        "id": "section_padding",
        "min": 0,
        "max": 160,
        "step": 4,
        "unit": "px",
        "label": "t:labels.section_padding",
        "default": 80
      },
      {
        "type": "range",
        "id": "section_padding_mobile",
        "min": 0,
        "max": 120,
        "step": 4,
        "unit": "px",
        "label": "t:labels.section_padding_mobile",
        "default": 32
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "select",
        "id": "font_scheme",
        "label": "t:labels.font_scheme",
        "default": "display",
        "info": "t:labels.font_scheme_info",
        "options": [
          { "value": "display", "label": "t:options.font_scheme.display" },
          { "value": "body", "label": "t:options.font_scheme.body" },
          { "value": "editorial", "label": "t:options.font_scheme.editorial" },
          { "value": "soft", "label": "t:options.font_scheme.soft" },
          { "value": "bold", "label": "t:options.font_scheme.bold" },
          { "value": "uniform", "label": "t:options.font_scheme.uniform" }
        ]
      }
    ]
  },
  {
    "name": "t:general.cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_drawer_auto_open",
        "label": "t:labels.cart_drawer_auto_open",
        "default": true
      }
    ]
  },
  {
    "name": "t:general.empty_states",
    "settings": [
      {
        "type": "link_list",
        "id": "empty_state_menu",
        "label": "t:labels.empty_state_menu",
        "info": "t:labels.empty_state_menu_info",
        "default": "main-menu"
      }
    ]
  }
]
