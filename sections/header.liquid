{% liquid
  assign is_homepage = false
  if request.page_type == 'index'
    assign is_homepage = true
  endif

  assign header_text_color = section.settings.text_color | default: 'steel'
  assign header_classes = 'site-header full-width z-50 flex w-full min-h-0 justify-center [&_a]:text-inherit [&_svg]:text-inherit'
%}

<header
  class="{{ header_classes }} {% if is_homepage %}{% render 'brand-text-color-class', color: header_text_color %}{% endif %}"
  data-site-header
  data-section-id="{{ section.id }}"
  {% if is_homepage %}
    data-site-header-scroll
  {% endif %}
>
  <div class="site-header__inner flex min-h-0 w-full flex-nowrap items-center gap-4">
    <nav
      class="site-header__nav flex min-h-0 min-w-0 flex-1 flex-nowrap items-center justify-start gap-4 text-sm [&_a]:relative [&_a]:inline-flex [&_a]:items-center [&_a]:justify-center [&_a]:font-bold [&_a]:no-underline [&_a]:hover:text-brand-rust"
      aria-label="{{ 'sections.header.main_navigation' | t }}"
    >
      {% for link in section.settings.menu.links %}
        <a
          href="{{ link.url }}"
          {% if link.active %}
            aria-current="page"
          {% endif %}
        >
          {{ link.title }}
        </a>
      {% endfor %}
    </nav>

    <a
      class="site-header__logo relative inline-flex min-h-0 shrink-0 items-center justify-center no-underline hover:text-brand-rust"
      href="{{ routes.root_url }}"
    >
      {% if settings.logo %}
        {{
          settings.logo
          | image_url: width: 400
          | image_tag: alt: shop.name, class: 'site-header__logo-mark object-contain'
        }}
      {% else %}
        <span class="sr-only">{{ shop.name }}</span>
        <span class="site-header__logo-mark">{{ 'logo.svg' | inline_asset_content }}</span>
      {% endif %}
    </a>

    <div class="site-header__utilities flex min-h-0 min-w-0 flex-1 items-center justify-end gap-4 text-sm">
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          <span slot="signed-out-avatar" class="site-header__account-trigger">
            {{ 'icon-account.svg' | inline_asset_content }}
          </span>
        </shopify-account>
      {% endif %}

      <button
        type="button"
        class="site-header__icon-btn"
        data-cart-drawer-open
        aria-label="{% if cart.item_count == 0 %}{{ 'cart.drawer_title' | t }}{% elsif cart.item_count == 1 %}{{ 'cart.drawer_title_one' | t }}{% else %}{{ 'cart.drawer_title_with_count' | t: count: cart.item_count }}{% endif %}"
      >
        <span data-hydration-key="header-cart" class="site-header__cart-badge">
          {% if cart.item_count > 0 %}
            <sup class="absolute left-full max-w-(--page-margin) overflow-hidden" aria-hidden="true">
              {{- cart.item_count -}}
            </sup>
          {% endif %}
        </span>

        <span class="site-header__icon-svg" aria-hidden="true">{{ 'icon-cart.svg' | inline_asset_content }}</span>
      </button>
    </div>
  </div>
</header>

{% style %}
  /* Shopify section groups have no wrapper — only this section is sticky. */
  .shopify-section.header-section {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    margin: 0;
    padding: 0;
    background: transparent;
    align-self: flex-start;
  }

  .template-index main {
    margin-top: calc(-1 * var(--header-height));
  }

  .site-header {
    box-sizing: border-box;
    padding-block: var(--header-padding-y-scrolled);
    background-color: #fff;
    color: var(--color-brand-steel);
  }

  .template-index [data-site-header-scroll] {
    padding-block: calc(
      var(--header-padding-y) + (var(--header-padding-y-scrolled) - var(--header-padding-y)) *
        var(--header-scroll-progress)
    );
    background-color: color-mix(in srgb, transparent, #fff calc(var(--header-scroll-progress) * 100%));
    color: color-mix(in srgb, #fff, var(--color-brand-steel) calc(var(--header-scroll-progress) * 100%));
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__logo-mark {
      transition: none;
    }
  }

  .site-header__inner {
    box-sizing: border-box;
    max-width: min(calc(var(--page-width) - var(--page-margin) * 2), calc(100% - var(--page-margin) * 2));
    padding-inline: var(--page-margin);
  }

  .site-header__logo-mark {
    display: block;
    max-height: var(--header-logo-max-height-scrolled);
    width: auto;
    max-width: min(12rem, 40vw);
  }

  .template-index [data-site-header-scroll] .site-header__logo-mark {
    max-height: calc(
      var(--header-logo-max-height) + (var(--header-logo-max-height-scrolled) - var(--header-logo-max-height)) *
        var(--header-scroll-progress)
    );
  }

  .site-header__logo-mark :where(img, svg) {
    display: block;
    width: auto;
    max-width: min(12rem, 40vw);
    height: auto;
    max-height: inherit;
  }

  .site-header__icon-btn,
  .site-header__utilities shopify-account {
    position: relative;
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: var(--header-icon-size-scrolled);
    height: var(--header-icon-size-scrolled);
    line-height: 0;
    color: inherit;
    transform: none;
    backface-visibility: hidden;
    transition: none;
  }

  .template-index [data-site-header-scroll] .site-header__icon-btn,
  .template-index [data-site-header-scroll] .site-header__utilities shopify-account {
    width: calc(
      var(--header-icon-size) + (var(--header-icon-size-scrolled) - var(--header-icon-size)) *
        var(--header-scroll-progress)
    );
    height: calc(
      var(--header-icon-size) + (var(--header-icon-size-scrolled) - var(--header-icon-size)) *
        var(--header-scroll-progress)
    );
  }

  .site-header__icon-btn {
    border: none;
    background: transparent;
    cursor: pointer;
    font: inherit;
    text-decoration: none;
  }

  .site-header__icon-btn:hover {
    color: var(--color-brand-rust);
  }

  .site-header__icon-btn:focus-visible {
    outline: 2px solid var(--color-brand-rust);
    outline-offset: 2px;
  }

  .site-header__icon-svg {
    display: contents;
  }

  .site-header__icon-btn :where(svg),
  .site-header__account-trigger :where(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .site-header__utilities shopify-account {
    --shopify-account-avatar-size: var(--header-icon-size-scrolled);
    --shopify-account-signed-in-avatar-size: var(--header-icon-size-scrolled);
    --shopify-account-color-accent: currentcolor;
    --shopify-account-color-accent-hover: var(--color-brand-rust);
    --shopify-account-color-border: transparent;
  }

  .site-header__utilities shopify-account::part(signed-out-avatar) {
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    outline: none;
    box-shadow: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    transition: none;
  }

  .site-header__utilities shopify-account::part(signed-out-avatar):hover {
    color: var(--color-brand-rust);
  }

  .site-header__utilities shopify-account::part(signed-out-avatar):focus-visible {
    outline: 2px solid var(--color-brand-rust);
    outline-offset: 2px;
  }

  .site-header__account-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: inherit;
    pointer-events: none;
  }

  .template-index [data-site-header-scroll] .site-header__utilities shopify-account {
    --shopify-account-avatar-size: calc(
      var(--header-icon-size) + (var(--header-icon-size-scrolled) - var(--header-icon-size)) *
        var(--header-scroll-progress)
    );
    --shopify-account-signed-in-avatar-size: calc(
      var(--header-icon-size) + (var(--header-icon-size-scrolled) - var(--header-icon-size)) *
        var(--header-scroll-progress)
    );
  }
{% endstyle %}

<script>
  (function () {
    var header = document.querySelector('[data-site-header]');
    if (!header) return;

    function syncHeaderHeight() {
      var height = header.offsetHeight + 'px';
      document.documentElement.style.setProperty('--header-height', height);
      document.documentElement.style.setProperty('--header-height-scrolled', height);
    }

    syncHeaderHeight();
    window.addEventListener('resize', syncHeaderHeight, { passive: true });

    if (typeof ResizeObserver !== 'undefined') {
      new ResizeObserver(syncHeaderHeight).observe(header);
    }
  })();
</script>

{% unless request.design_mode %}
  <script type="module">
    import { hydrate } from '@theme/section-hydration';
    hydrate('{{ section.id }}');
  </script>
{% endunless %}

{% javascript %}
  (function () {
    var header = document.querySelector('[data-site-header]');
    if (!header || !header.hasAttribute('data-site-header-scroll')) return;

    var root = document.documentElement;
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    var shrinkRange = parseFloat(getComputedStyle(root).getPropertyValue('--header-shrink-scroll-range')) || 96;
    var ticking = false;

    function setScrollProgress() {
      ticking = false;
      var progress;

      if (reduceMotion.matches) {
        progress = window.scrollY > 0 ? 1 : 0;
      } else {
        progress = Math.min(1, Math.max(0, window.scrollY / shrinkRange));
      }

      root.style.setProperty('--header-scroll-progress', String(progress));
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(setScrollProgress);
      }
    }

    reduceMotion.addEventListener('change', setScrollProgress);
    setScrollProgress();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', setScrollProgress, { passive: true });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "class": "header-section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "t:sections.header.settings.text_color_label",
      "default": "steel",
      "options": [
        {
          "value": "white",
          "label": "t:options.brand_color.white"
        },
        {
          "value": "steel",
          "label": "t:options.brand_color.steel"
        },
        {
          "value": "rust",
          "label": "t:options.brand_color.rust"
        },
        {
          "value": "earth",
          "label": "t:options.brand_color.earth"
        },
        {
          "value": "warmth",
          "label": "t:options.brand_color.warmth"
        },
        {
          "value": "heart",
          "label": "t:options.brand_color.heart"
        }
      ]
    }
  ]
}
{% endschema %}
