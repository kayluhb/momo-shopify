{% liquid
  assign columns = section.settings.columns
  assign logo_height = section.settings.logo_height
%}
{% capture section_bg %}{% render 'section-color-scheme', scheme: section.settings.color_scheme %}{% endcapture %}

<section
  id="shopify-section-{{ section.id }}"
  class="logo-list full-width py-12 md:py-16 {{ section_bg }}{% if section.settings.grayscale %} logo-list--grayscale{% endif %}"
  style="--logo-height: {{ logo_height }}px"
>
  <div class="section-inner">
    {% render 'section-heading',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading,
      alignment: 'center'
    %}

    {% if section.blocks.size > 0 %}
      <ul
        class="logo-list__grid list-none p-0"
        style="--columns: {{ columns }}"
        role="list"
      >
        {% for block in section.blocks %}
          <li {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a class="logo-list__item" href="{{ block.settings.link }}" target="_blank" rel="noopener noreferrer">
            {% else %}
              <div class="logo-list__item">
            {% endif %}
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 300
                  | image_tag:
                    loading: 'lazy',
                    widths: '150,200,300',
                    class: 'logo-list__img',
                    alt: block.settings.image.alt
                    | default: 'Logo'
                }}
              {% else %}
                <div class="logo-list__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
              {% endif %}
            {% if block.settings.link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .logo-list__grid {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 2rem 3rem;
  }

  @media (min-width: 750px) {
    .logo-list__grid {
      display: grid;
      grid-template-columns: repeat(var(--columns, 5), minmax(0, 1fr));
      gap: 2rem;
    }
  }

  .logo-list__item {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--logo-height, 40px);
    text-decoration: none;
  }

  .logo-list__img {
    width: auto;
    max-width: 100%;
    max-height: var(--logo-height, 40px);
    height: auto;
    object-fit: contain;
  }

  .logo-list--grayscale .logo-list__img {
    filter: grayscale(100%);
    opacity: 0.7;
    transition: filter 0.25s ease, opacity 0.25s ease;
  }

  .logo-list--grayscale .logo-list__item:hover .logo-list__img {
    filter: grayscale(0%);
    opacity: 1;
  }

  .logo-list__placeholder {
    width: 6rem;
    opacity: 0.35;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.logo_list.name",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "t:sections.shared.content_header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.shared.eyebrow_label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.shared.heading_label",
      "default": "As seen in"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.shared.subheading_label"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.shared.columns_desktop_label",
      "min": 4,
      "max": 6,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "t:sections.logo_list.logo_height_label",
      "min": 24,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "t:sections.logo_list.grayscale_label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.shared.appearance_header"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme_label",
      "default": "white",
      "options": [
        { "value": "white", "label": "t:options.color_scheme.white" },
        { "value": "canvas", "label": "t:options.color_scheme.canvas" },
        { "value": "earth", "label": "t:options.color_scheme.earth" },
        { "value": "steel", "label": "t:options.color_scheme.steel" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "t:sections.logo_list.blocks.logo.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.logo_list.blocks.logo.image_label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.shared.link_url_label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.logo_list.presets.default_name",
      "settings": {
        "heading": "As seen in",
        "columns": 5,
        "grayscale": true,
        "color_scheme": "white"
      },
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
