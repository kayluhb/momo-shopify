{% doc %}
  Renders an optional section header with eyebrow, heading, subheading, and CTA link.

  @param {string} [eyebrow] - Small label above the heading
  @param {string} [heading] - Main section title
  @param {string} [subheading] - Supporting text below the heading
  @param {string} [link_label] - Optional CTA link label
  @param {string} [link_url] - Optional CTA link URL
  @param {string} [alignment] - left or center (default: left)
  @param {boolean} [heading_display] - Use larger display heading size
  @param {string} [heading_id] - Optional id for the heading element
  @param {string} [class] - Additional CSS classes on the wrapper

  @example
  {% render 'section-heading',
    heading: section.settings.heading,
    subheading: section.settings.subheading,
    alignment: 'center'
  %}
{% enddoc %}

{% liquid
  assign alignment = alignment | default: 'left'
  assign has_content = false

  if eyebrow != blank or heading != blank or subheading != blank
    assign has_content = true
  endif

  if link_label != blank and link_url != blank
    assign has_content = true
  endif
%}

{% if has_content %}
  <header class="section-heading section-heading--{{ alignment }} {{ class }}">
    {% if eyebrow != blank %}
      <p class="section-heading__eyebrow type-eyebrow">{{ eyebrow | escape }}</p>
    {% endif %}

    {% if heading != blank %}
      <h2
        class="section-heading__title{% if heading_display %} section-heading__title--display{% endif %}"
        {% if heading_id != blank %}
          id="{{ heading_id }}"
        {% endif %}
      >
        {{ heading | escape }}
      </h2>
    {% endif %}

    {% if subheading != blank %}
      <div class="section-heading__subheading">{{ subheading }}</div>
    {% endif %}

    {% if link_label != blank and link_url != blank %}
      <div class="section-heading__cta">
        {% render 'button', label: link_label, url: link_url, style: 'secondary' %}
      </div>
    {% endif %}
  </header>
{% endif %}

{% stylesheet %}
  .section-heading {
    margin-bottom: var(
      --section-heading-stack-margin-bottom,
      var(--section-header-stack-gap, 2.75rem)
    );
  }

  .section-heading--center {
    text-align: center;
  }

  .section-heading--center .section-heading__cta {
    justify-content: center;
  }

  .section-heading__eyebrow {
    margin: 0 0 var(
      --section-heading-eyebrow-margin-bottom,
      var(--section-header-eyebrow-gap, 0.375rem)
    );
  }

  .section-heading__subheading :where(a) {
    font-weight: var(--font-weight-bold, 700);
    color: var(--color-brand-rust);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .section-heading__title {
    margin: 0 0 var(
      --section-heading-title-margin-bottom,
      var(--section-header-title-gap, 0.375rem)
    );
    font-size: var(--section-heading-title-size, clamp(1.75rem, 4vw, 2.5rem));
    font-weight: var(--font-heading-weight, var(--font-weight-bold, 700));
    font-style: var(--font-heading-font-style, normal);
    line-height: var(--font-heading-line-height, 1.1);
    text-transform: var(--font-heading-text-transform, none);
  }

  .section-heading__title--display {
    font-size: var(
      --section-heading-title-size-display,
      clamp(2.5rem, 6vw, 3.75rem)
    );
    line-height: 1.02;
    letter-spacing: var(--font-heading-letter-spacing, -0.03em);
  }

  .section-heading__subheading {
    display: block;
    margin: 0;
    max-width: 42rem;
    font-size: var(--font-body-size, 1rem);
    line-height: var(--font-body-line-height, 1.6);
  }

  .section-heading--center .section-heading__subheading {
    margin-inline: auto;
  }

  .section-heading__subheading :where(p) {
    margin: 0;
  }

  .section-heading__cta {
    display: flex;
    margin-top: 1.25rem;
  }
{% endstylesheet %}
