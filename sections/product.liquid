{% liquid
  assign product_layout = section.settings.layout | default: 'split'
  assign image_position = section.settings.image_position | default: 'left'
  capture section_bg
    render 'section-color-scheme', scheme: section.settings.color_scheme
  endcapture
%}

<section
  id="shopify-section-{{ section.id }}"
  class="product-section full-width product-section--{{ product_layout }} {{ section_bg }}"
  {{ section.shopify_attributes }}
>
  <variant-picker
    class="product-section__picker"
    data-section-id="{{ section.id }}"
    data-product-url="{{ product.url }}"
    data-product-id="{{ product.id }}"
  >
    {% if product_layout == 'hero' %}
      {% render 'product-gallery',
        product: product,
        layout: 'hero',
        section_id: section.id,
        hero_height: section.settings.hero_height,
        overlay_opacity: section.settings.overlay_opacity
      %}

      <div class="section-inner product-section__buy product-section__buy--hero">
        {% render 'product-buy-box', product: product, section_id: section.id, layout: 'hero' %}
      </div>
    {% elsif product_layout == 'split_half' %}
      <div class="product-section__split-half product-section__split-half--image-{{ image_position }}">
        {% render 'product-gallery', product: product, layout: 'split_half', section_id: section.id %}

        <div class="product-section__details">
          {% render 'product-buy-box', product: product, section_id: section.id, layout: 'split_half' %}
        </div>
      </div>
    {% else %}
      <div class="section-inner product-section__inner product-section__inner--image-{{ image_position }}">
        {% render 'product-gallery', product: product, layout: product_layout, section_id: section.id %}

        {% render 'product-buy-box', product: product, section_id: section.id, layout: product_layout %}
      </div>
    {% endif %}
  </variant-picker>
</section>

{% stylesheet %}
  .product-section {
    padding-block: 3.5rem;
  }

  @media (min-width: 750px) {
    .product-section {
      padding-block: 5rem;
    }
  }

  .product-section--hero,
  .product-section--split_half {
    padding-block: 0;
  }

  .product-section__picker {
    display: block;
  }

  .product-section__inner {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }

  @media (min-width: 990px) {
    .product-section__inner {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .product-section__inner--image-right .product-gallery {
      order: 2;
    }
  }

  .product-section__split-half {
    display: grid;
    gap: 0;
    align-items: start;
  }

  @media (min-width: 990px) {
    .product-section__split-half {
      grid-template-columns: 1fr 1fr;
      min-height: calc(100svh - var(--header-height, 0px) - var(--announcement-bar-height, 0px));
    }

    .product-section__split-half--image-right .product-gallery {
      order: 2;
    }

    .product-section__details {
      position: sticky;
      top: calc(var(--header-height, 0px) + var(--announcement-bar-height, 0px));
      align-self: start;
      box-sizing: border-box;
      min-height: calc(100svh - var(--header-height, 0px) - var(--announcement-bar-height, 0px));
      padding: 2.5rem clamp(1.5rem, 4vw, 3.5rem);
    }
  }

  @media (max-width: 989px) {
    .product-section__details {
      padding-block: 2.5rem;
      padding-inline: var(--page-margin);
    }
  }

  @media (max-width: 749px) {
    .product-section__details {
      padding-inline: var(--page-margin-mobile);
    }
  }

  .product-section__buy--hero {
    padding-block: 2.5rem 3.5rem;
  }

  @media (min-width: 750px) {
    .product-section__buy--hero {
      padding-block: 3rem 5rem;
    }
  }

  .product-section .product-form__status {
    margin: 0;
    font-size: 0.875rem;
  }

  @media (max-width: 749px) {
    .product-section--split,
    .product-section--split_tall {
      padding-block: 0 3.5rem;
    }

    .product-section--split .product-section__inner .product-gallery,
    .product-section--split_tall .product-section__inner .product-gallery {
      width: calc(100% + var(--page-margin-mobile) * 2);
      max-width: none;
      margin-inline: calc(-1 * var(--page-margin-mobile));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product.name",
  "tag": "section",
  "class": "section-product",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.shared.appearance_header"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme_label",
      "default": "canvas",
      "options": [
        { "value": "white", "label": "t:options.color_scheme.white" },
        { "value": "canvas", "label": "t:options.color_scheme.canvas" },
        { "value": "earth", "label": "t:options.color_scheme.earth" },
        { "value": "steel", "label": "t:options.color_scheme.steel" }
      ]
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.product.layout_label",
      "default": "split",
      "options": [
        { "value": "split", "label": "t:sections.product.layout_options.split" },
        { "value": "split_tall", "label": "t:sections.product.layout_options.split_tall" },
        { "value": "split_half", "label": "t:sections.product.layout_options.split_half" },
        { "value": "hero", "label": "t:sections.product.layout_options.hero" }
      ]
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.product.image_position_label",
      "default": "left",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "right", "label": "t:options.alignment.right" }
      ]
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "rem",
      "label": "t:sections.product.hero_height_label",
      "default": 42,
      "visible_if": "{{ section.settings.layout == 'hero' }}"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "t:sections.product.overlay_opacity_label",
      "default": 35,
      "visible_if": "{{ section.settings.layout == 'hero' }}"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
