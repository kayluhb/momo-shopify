{% doc %}
  Loads theme JavaScript modules (Section Rendering API + morph stack) and the Theme global.

  @example
  {% render 'scripts' %}
{% enddoc %}

{% render 'storefront-components' %}

{% liquid
  assign theme_module_files = 'cart-icon.js,cart-items.js,cart-sections.js,collection-facets.js,component.js,dialog.js,events.js,morph.js,product-cart.js,product-recommendations.js,photoswipe.esm.min.js,photoswipe-lightbox.esm.min.js,product-gallery.js,product-card-swatches.js,section-hydration.js,section-renderer.js,utilities.js,variant-picker.js' | split: ','
  assign theme_preload_files = 'utilities.js,component.js,morph.js,section-renderer.js,section-hydration.js,events.js,dialog.js,cart-sections.js,cart-items.js,cart-icon.js'
  assign collection_module_files = 'collection-facets.js,product-card-swatches.js'
%}

<script type="importmap">
  {
    "imports": {
      {%- for module_file in theme_module_files -%}
        {%- assign module_key = module_file | replace: '.esm.min.js', '' | replace: '.js', '' -%}
        "@theme/{{ module_key }}": "{{ module_file | asset_url }}"{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    }
  }
</script>

{% assign preload_files = theme_preload_files | split: ',' %}
{% for preload_file in preload_files %}
  <link rel="modulepreload" href="{{ preload_file | asset_url }}" fetchpriority="low">
{% endfor %}

<script src="{{ 'cart-icon.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'cart-items.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'cart-drawer.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'menu-drawer.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'menu-icon.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% if template.name == 'product' %}
  {{ 'photoswipe.css' | asset_url | stylesheet_tag }}
  {% assign product_preload_files = 'photoswipe.esm.min.js,photoswipe-lightbox.esm.min.js,product-cart.js,product-gallery.js,product-recommendations.js,product-card-swatches.js,variant-picker.js' | split: ',' %}
  {% for preload_file in product_preload_files %}
    <link rel="modulepreload" href="{{ preload_file | asset_url }}" fetchpriority="low">
  {% endfor %}
  <script src="{{ 'product-gallery.js' | asset_url }}" type="module" fetchpriority="low"></script>
  <script src="{{ 'product-cart.js' | asset_url }}" type="module" fetchpriority="low"></script>
  <script src="{{ 'product-recommendations.js' | asset_url }}" type="module" fetchpriority="low"></script>
  <script src="{{ 'product-card-swatches.js' | asset_url }}" type="module" fetchpriority="low"></script>
  <script src="{{ 'variant-picker.js' | asset_url }}" type="module" fetchpriority="low"></script>
{% endif %}

{% if template.name == 'collection' %}
  {% assign collection_preload_files = collection_module_files | split: ',' %}
  {% for preload_file in collection_preload_files %}
    <link rel="modulepreload" href="{{ preload_file | asset_url }}" fetchpriority="low">
  {% endfor %}
  <script src="{{ 'collection-facets.js' | asset_url }}" type="module" fetchpriority="low"></script>
  <script src="{{ 'product-card-swatches.js' | asset_url }}" type="module" fetchpriority="low"></script>
{% endif %}

{% liquid
  assign cart_add_url = routes.cart_add_url
  unless cart_add_url contains '.js'
    assign cart_add_url = cart_add_url | append: '.js'
  endunless

  assign cart_change_url = routes.cart_change_url
  unless cart_change_url contains '.js'
    assign cart_change_url = cart_change_url | append: '.js'
  endunless
%}

<script>
  const Theme = {
    translations: {
      add_to_cart_loading: {{ 'products.add_to_cart.loading' | t | json }},
      add_to_cart_success: {{ 'products.add_to_cart.success' | t | json }},
      add_to_cart_error: {{ 'products.add_to_cart.error' | t | json }},
      remove_loading: {{ 'cart.remove_loading' | t | json }},
    },
    routes: {
      cart_add_url: {{ cart_add_url | json }},
      cart_change_url: {{ cart_change_url | json }},
      cart_update_url: '{{ routes.cart_update_url }}',
      cart_url: '{{ routes.cart_url }}',
    },
    template: {
      name: '{{ template.name }}',
    },
  };
</script>
