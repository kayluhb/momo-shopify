{% doc %}
  Renders an optional section header with eyebrow, heading, subheading, and CTA link.

  @param {string} [eyebrow] - Small label above the heading
  @param {string} [heading] - Main section title
  @param {string} [subheading] - Supporting text below the heading
  @param {string} [link_label] - Optional CTA link label
  @param {string} [link_url] - Optional CTA link URL
  @param {string} [alignment] - left or center (default: left)
  @param {string} [class] - Additional CSS classes on the wrapper

  @example
  {% render 'section-heading',
    heading: section.settings.heading,
    subheading: section.settings.subheading,
    alignment: 'center'
  %}
{% enddoc %}

{% liquid
  assign alignment = alignment | default: 'left'
  assign has_content = false

  if eyebrow != blank or heading != blank or subheading != blank
    assign has_content = true
  endif

  if link_label != blank and link_url != blank
    assign has_content = true
  endif
%}

{% if has_content %}
  <header class="section-heading section-heading--{{ alignment }} {{ class }}">
    {% if eyebrow != blank %}
      <p class="section-heading__eyebrow">{{ eyebrow | escape }}</p>
    {% endif %}

    {% if heading != blank %}
      <h2 class="section-heading__title">{{ heading | escape }}</h2>
    {% endif %}

    {% if subheading != blank %}
      <div class="section-heading__subheading">{{ subheading }}</div>
    {% endif %}

    {% if link_label != blank and link_url != blank %}
      <div class="section-heading__cta">
        {% render 'button', label: link_label, url: link_url, style: 'secondary' %}
      </div>
    {% endif %}
  </header>
{% endif %}

{% stylesheet %}
  .section-heading {
    margin-bottom: 2rem;
  }

  .section-heading--center {
    text-align: center;
  }

  .section-heading--center .section-heading__cta {
    justify-content: center;
  }

  .section-heading__eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.3;
    text-transform: uppercase;
    color: var(--color-brand-rust, #c57639);
  }

  :where(.bg-brand-earth, .bg-brand-steel, .bg-brand-warmth, .bg-brand-heart) .section-heading__eyebrow {
    color: var(--color-brand-warmth, #ea7657);
  }

  .section-heading__subheading :where(a) {
    font-weight: 600;
    color: var(--color-brand-rust, #c57639);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  :where(.bg-brand-earth, .bg-brand-steel, .bg-brand-warmth, .bg-brand-heart) .section-heading__subheading :where(a) {
    color: #fff;
  }

  .section-heading__title {
    margin: 0 0 0.75rem;
    font-family: var(--font-display--family, var(--font-primary--family));
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.15;
  }

  .section-heading__subheading {
    display: block;
    margin: 0;
    max-width: 42rem;
    font-size: 1rem;
    line-height: 1.6;
  }

  .section-heading--center .section-heading__subheading {
    margin-inline: auto;
  }

  .section-heading__subheading :where(p) {
    margin: 0;
  }

  .section-heading__cta {
    display: flex;
    margin-top: 1.25rem;
  }
{% endstylesheet %}
