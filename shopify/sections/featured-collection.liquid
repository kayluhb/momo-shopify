{% liquid
  assign collection = section.settings.collection
  assign products_limit = section.settings.products_to_show
  assign columns = section.settings.columns
  assign view_all_url = collection.url
  if section.settings.view_all_link != blank
    assign view_all_url = section.settings.view_all_link
  endif
%}
{% capture section_bg %}{% render 'section-color-scheme', scheme: section.settings.color_scheme %}{% endcapture %}

<section
  id="shopify-section-{{ section.id }}"
  class="featured-collection full-width py-14 md:py-20 {{ section_bg }}"
>
  <div class="section-inner">
    {% render 'section-heading',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading,
      alignment: section.settings.heading_alignment
    %}

    {% if collection != blank and collection.products_count > 0 %}
      <ul
        class="featured-collection__grid list-none p-0"
        style="--columns: {{ columns }}"
        role="list"
      >
        {% for product in collection.products limit: products_limit %}
          <li>
            {% render 'product-card', product: product %}
          </li>
        {% endfor %}
      </ul>

      {% if section.settings.show_view_all and view_all_url != blank %}
        {% liquid
          assign view_all_label = section.settings.view_all_label
          if view_all_label == blank
            assign view_all_label = 'general.view_all' | t
          endif
        %}
        <div class="featured-collection__footer">
          {% render 'button', label: view_all_label, url: view_all_url, style: 'secondary' %}
        </div>
      {% endif %}
    {% else %}
      <p class="featured-collection__empty">{{ 'sections.featured_collection.empty' | t }}</p>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .featured-collection__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (min-width: 750px) {
    .featured-collection__grid {
      grid-template-columns: repeat(var(--columns, 4), minmax(0, 1fr));
    }
  }

  .featured-collection__footer {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .featured-collection__empty {
    margin: 0;
    text-align: center;
    opacity: 0.75;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.shared.content_header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.shared.eyebrow_label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.shared.heading_label",
      "default": "Featured collection"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.shared.subheading_label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.shared.heading_alignment_label",
      "default": "center",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection.collection_header"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_collection.collection_label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.featured_collection.products_to_show_label",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.shared.columns_desktop_label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:sections.featured_collection.show_view_all_label",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:sections.featured_collection.view_all_label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "t:sections.featured_collection.view_all_link_label",
      "info": "t:sections.featured_collection.view_all_link_info"
    },
    {
      "type": "header",
      "content": "t:sections.shared.appearance_header"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme_label",
      "default": "white",
      "options": [
        { "value": "white", "label": "t:options.color_scheme.white" },
        { "value": "canvas", "label": "t:options.color_scheme.canvas" },
        { "value": "earth", "label": "t:options.color_scheme.earth" },
        { "value": "steel", "label": "t:options.color_scheme.steel" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.presets.default_name",
      "settings": {
        "heading": "Curated for you",
        "subheading": "<p>Discover pieces crafted with intention and designed to endure.</p>",
        "heading_alignment": "center",
        "products_to_show": 4,
        "columns": 4,
        "show_view_all": true,
        "view_all_label": "View all",
        "color_scheme": "white"
      }
    }
  ]
}
{% endschema %}
