{% comment %}
  Cart page with AJAX line-item updates via cart-items-component.
{% endcomment %}

<h1>{{ 'cart.title' | t }}</h1>

{% render 'cart-line-items', section_id: section.id %}

{% unless cart.empty? %}
  <form action="{{ routes.cart_url }}" method="post" class="cart-page__checkout">
    <button type="submit" name="checkout">
      {{ 'cart.checkout' | t }}
    </button>
  </form>
{% endunless %}

{% stylesheet %}
  .cart-page__checkout {
    margin-top: 1.5rem;
  }

  .cart-page__checkout button {
    padding: 0.75rem 1.25rem;
    border-radius: var(--style-border-radius);
    border: none;
    background: var(--color-brand-steel);
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-weight: 600;
  }

  .cart-items__header,
  .cart-items__row {
    padding-inline: 0.5rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
