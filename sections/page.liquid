{% comment %}
  Renders Shopify page content with theme layout and typography.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/page
{% endcomment %}

{% capture section_bg %}{% render 'section-color-scheme', scheme: section.settings.color_scheme %}{% endcapture %}
{% capture section_font %}{% render 'section-font-scheme', scheme: section.settings.font_scheme %}{% endcapture %}

<section
  id="shopify-section-{{ section.id }}"
  class="page-content full-width section-padding {{ section_bg }} {{ section_font }}"
>
  <div class="section-inner page-content__inner">
    {% if section.settings.show_title %}
      <h1 class="page-content__title">{{ page.title }}</h1>
    {% endif %}

    {% if page.content != blank %}
      <div class="page-content__body rte">
        {{ page.content }}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .page-content .section-inner {
    width: 100%;
    max-width: min(42rem, 100%);
  }

  .page-content__title {
    margin: 0 0 clamp(1.25rem, 3vw, 2rem);
    font-size: var(--page-heading-size, clamp(2rem, 5vw, 3rem));
    font-weight: var(--font-heading-weight, var(--font-weight-bold, 700));
    font-style: var(--font-heading-font-style, normal);
    line-height: var(--font-heading-line-height, 1.05);
    text-wrap: balance;
    text-transform: var(--font-heading-text-transform, none);
  }

  .page-content__body {
    font-size: 1rem;
  }

  .page-content__body :where(p) {
    margin: 0 0 1rem;
  }

  .page-content__body :where(p:last-child) {
    margin-bottom: 0;
  }

  .page-content__body :where(h2, h3, h4) {
    margin: clamp(1.75rem, 4vw, 2.5rem) 0 0.75rem;
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    line-height: 1.2;
    text-wrap: balance;
  }

  .page-content__body :where(h2:first-child, h3:first-child, h4:first-child) {
    margin-top: 0;
  }

  .page-content__body :where(ul, ol) {
    margin: 0 0 1rem;
    padding-inline-start: 1.25rem;
  }

  .page-content__body :where(li + li) {
    margin-top: 0.35rem;
  }

  .page-content__body :where(a) {
    font-weight: var(--font-weight-bold, 700);
    color: var(--color-brand-rust);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .page-content__body :where(a):hover {
    color: color-mix(in srgb, var(--color-brand-rust) 82%, #000);
  }

  .page-content__body :where(a):focus-visible {
    outline-color: var(--color-brand-rust);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.page",
  "tag": "section",
  "class": "section-page",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.shared.appearance_header"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme_label",
      "default": "white",
      "options": [
        { "value": "white", "label": "t:options.color_scheme.white" },
        { "value": "canvas", "label": "t:options.color_scheme.canvas" },
        { "value": "earth", "label": "t:options.color_scheme.earth" },
        { "value": "steel", "label": "t:options.color_scheme.steel" }
      ]
    },
    {
      "type": "select",
      "id": "font_scheme",
      "label": "t:sections.shared.font_scheme_label",
      "default": "display",
      "options": [
        { "value": "display", "label": "t:options.font_scheme.display" },
        { "value": "editorial", "label": "t:options.font_scheme.editorial" },
        { "value": "soft", "label": "t:options.font_scheme.soft" },
        { "value": "bold", "label": "t:options.font_scheme.bold" },
        { "value": "uniform", "label": "t:options.font_scheme.uniform" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "t:sections.page.show_title_label",
      "default": true
    }
  ]
}
{% endschema %}
