{% doc %}
  Renders product title, price, description, and add-to-cart form.

  @param {product} product - The product to display
  @param {string} section_id - Section ID for form field IDs
  @param {string} [layout] - split, split_tall, split_half, or hero (controls sticky buy column)
{% enddoc %}

{% liquid
  assign buy_layout = layout | default: 'split'
  assign is_sticky = false
  if buy_layout != 'hero'
    assign is_sticky = true
  endif

  assign current_variant = product.selected_variant
  if current_variant == blank
    assign current_variant = product.selected_or_first_available_variant
  endif
  assign variant_available = current_variant.available
%}

<div class="product-buy product-buy--{{ buy_layout }}{% if is_sticky %} product-buy--sticky{% endif %}">
  {% render 'breadcrumbs', product: product %}

  <h1 class="product-buy__title">{{ product.title | escape }}</h1>

  {% render 'product-review-summary', product: product %}

  <p class="product-buy__price" data-variant-price>
    {{ current_variant.price | money }}
  </p>

  {% if product.description != blank %}
    <div class="product-buy__description rte">
      {{ product.description }}
    </div>
  {% endif %}

  <div class="product-buy__form" data-product-form>
    {% form 'product', product %}
      {% unless product.has_only_default_variant %}
        <div class="product-buy__options" data-product-options>
          {% for option in product.options_with_values %}
            {% liquid
              assign option_name_down = option.name | downcase
              assign is_color_option = false
              if option_name_down == 'color' or option_name_down == 'colour'
                assign is_color_option = true
              endif
            %}
            <fieldset class="product-buy__field product-buy__field--option">
              <legend class="product-buy__label">
                {{ option.name }}:
                <span class="product-buy__label-value">{{ option.selected_value }}</span>
              </legend>
              <div class="product-buy__option-values">
                {% for value in option.values %}
                  {% liquid
                    assign value_label = value.name | default: value
                    assign value_selected = false
                    if option.selected_value == value_label
                      assign value_selected = true
                    endif

                    assign value_available = false
                    for variant in product.variants
                      assign option_value = nil
                      case option.position
                        when 1
                          assign option_value = variant.option1
                        when 2
                          assign option_value = variant.option2
                        when 3
                          assign option_value = variant.option3
                      endcase
                      if option_value == value_label and variant.available
                        assign value_available = true
                        break
                      endif
                    endfor

                    assign variant_for_value = value.variant
                    if variant_for_value == blank
                      for variant in product.variants
                        case option.position
                          when 1
                            assign option_match = variant.option1
                          when 2
                            assign option_match = variant.option2
                          when 3
                            assign option_match = variant.option3
                        endcase
                        if option_match == value_label
                          assign variant_for_value = variant
                          break
                        endif
                      endfor
                    endif

                    assign swatch_bg = ''
                    assign swatch_image = nil
                    if is_color_option
                      if value.swatch.image != blank
                        assign swatch_image = value.swatch.image
                      elsif variant_for_value.featured_image
                        assign swatch_image = variant_for_value.featured_image
                      endif
                      if value.swatch.color != blank
                        assign swatch_bg = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                      elsif swatch_image == blank
                        assign color_key = value_label | downcase | strip
                        assign swatch_color_translation = 'products.swatch_colors.' | append: color_key
                        assign swatch_bg = swatch_color_translation | t
                        if swatch_bg == swatch_color_translation
                          assign swatch_bg = ''
                        endif
                      endif
                    endif

                    assign input_id = 'Option-'
                    assign input_id = input_id | append: section_id
                    assign input_id = input_id | append: '-'
                    assign input_id = input_id | append: option.position
                    assign input_id = input_id | append: '-'
                    assign input_id = input_id | append: forloop.index
                  %}
                  <input
                    type="radio"
                    id="{{ input_id }}"
                    class="product-buy__option-input"
                    name="option-{{ section_id }}-{{ option.position }}"
                    value="{{ value_label | escape }}"
                    data-product-option="{{ option.position }}"
                    {% if value_selected %}
                      checked
                    {% endif %}
                  >
                  <label
                    for="{{ input_id }}"
                    class="product-buy__option-btn focus-ring-brand{% if is_color_option %} product-buy__option-btn--swatch{% endif %}{% unless value_available %} product-buy__option-btn--unavailable{% endunless %}"
                    {% if is_color_option %}
                      aria-label="{{ option.name }}: {{ value_label }}{% unless value_available %} ({{ 'products.sold_out.label' | t }}){% endunless %}"
                    {% endif %}
                    {% if is_color_option and swatch_bg != blank %}
                      style="--swatch-bg: {{ swatch_bg }};"
                    {% endif %}
                  >
                    {% if is_color_option and swatch_image %}
                      {{
                        swatch_image
                        | image_url: width: 80, height: 80, crop: 'center'
                        | image_tag:
                          class: 'product-buy__option-swatch-img',
                          loading: 'lazy',
                          widths: '40, 80',
                          sizes: '44px',
                          alt: ''
                      }}
                    {% elsif is_color_option == false %}
                      <span class="product-buy__option-label">{{ value_label }}</span>
                    {% endif %}
                  </label>
                {% endfor %}
              </div>
            </fieldset>
          {% endfor %}
        </div>

        <select
          id="product-variant-{{ section_id }}"
          class="sr-only"
          name="id"
          tabindex="-1"
          aria-hidden="true"
        >
          {% for variant in product.variants %}
            <option
              value="{{ variant.id }}"
              {% if variant == current_variant %}
                selected
              {% endif %}
              {% unless variant.available %}
                disabled
              {% endunless %}
            >
              {{ variant.title }}
            </option>
          {% endfor %}
        </select>

        <script type="application/json" data-product-variant-data>
          {{ product.variants | json }}
        </script>
      {% else %}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
      {% endunless %}

      {% if variant_available %}
        {% render 'product-purchase-options',
          product: product,
          section_id: section_id,
          current_variant: current_variant
        %}

        <div class="product-buy__submit">
          {% assign add_to_cart_label = 'products.add_to_cart.label' | t %}
          {% render 'button',
            label: add_to_cart_label,
            tag: 'button',
            button_type: 'submit',
            style: 'primary',
            class: 'product-buy__add-to-cart'
          %}
        </div>

        <div class="product-buy__payment">
          {{ form | payment_button }}
        </div>

        {% if product.selling_plan_groups.size > 0 %}
          <p
            class="product-buy__preorder-disclosure"
            data-preorder-disclosure
            hidden
          >
            <span data-disclosure-content="preorder" hidden>
              {{- 'products.preorder.disclosure_before_policy' | t -}}
              {%- if shop.subscription_policy -%}
                <a href="{{ shop.subscription_policy.url }}">
                  {{- 'products.preorder.cancellation_policy' | t -}}
                </a>
              {%- else -%}
                {{- 'products.preorder.cancellation_policy' | t -}}
              {%- endif -%}
              {{- 'products.preorder.disclosure_after_policy' | t -}}
            </span>
            <span data-disclosure-content="subscription" hidden>
              {{- 'products.preorder.subscription_disclosure_before_policy' | t -}}
              {%- if shop.subscription_policy -%}
                <a href="{{ shop.subscription_policy.url }}">
                  {{- 'products.preorder.cancellation_policy' | t -}}
                </a>
              {%- else -%}
                {{- 'products.preorder.cancellation_policy' | t -}}
              {%- endif -%}
              {{- 'products.preorder.subscription_disclosure_after_policy' | t -}}
            </span>
          </p>
        {% endif %}
      {% else %}
        <div class="product-buy__sold-out" data-product-sold-out>
          <p class="product-buy__availability">{{ 'products.sold_out.label' | t }}</p>
          <div class="product-buy__submit">
            <button
              type="button"
              class="btn btn--primary product-buy__notify-trigger"
              on:click="#back-in-stock-{{ section_id }}/open"
            >
              {{ 'products.back_in_stock.open' | t }}
            </button>
          </div>
        </div>
      {% endif %}
    {% endform %}
  </div>

  {% render 'back-in-stock-dialog', product: product, variant: current_variant, section_id: section_id %}
</div>

{% stylesheet %}
  .product-buy--sticky {
    position: sticky;
    top: calc(var(--header-height, 0px) + 1rem);
    align-self: start;
  }

  .product-buy--hero {
    max-width: 42rem;
  }

  .product-section__details .product-buy--sticky {
    position: static;
    top: auto;
  }

  .product-buy .breadcrumbs {
    margin-bottom: 1rem;
  }

  .product-buy__title {
    margin: 0 0 0.5rem;
    font-size: var(--product-buy-title-size, clamp(1.875rem, 3.5vw, 2.375rem));
    line-height: var(--font-heading-line-height, 1.1);
    font-weight: var(--font-heading-weight, 700);
    font-style: var(--font-heading-font-style, normal);
    text-transform: var(--font-heading-text-transform, none);
  }

  .product-buy__reviews {
    margin: 0 0 0.75rem;
  }

  .product-buy__reviews-link {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .product-buy__reviews-link:hover,
  .product-buy__reviews-link:focus-visible {
    color: var(--color-brand-rust);
  }

  .product-buy__reviews-link:focus-visible {
    outline: 2px solid var(--color-brand-rust);
    outline-offset: 3px;
  }

  .product-buy__reviews-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: color-mix(in srgb, currentColor 72%, transparent);
  }

  .product-buy__reviews-score {
    font-weight: 700;
  }

  .product-buy__price {
    margin: 0 0 1.25rem;
    font-size: 1.125rem;
    font-weight: 600;
  }

  .product-buy__description {
    margin-bottom: 1.5rem;
    font-size: 1rem;
    line-height: 1.65;
  }

  .product-buy__description :where(p) {
    margin: 0 0 1rem;
  }

  .product-buy__description :where(p:last-child) {
    margin-bottom: 0;
  }

  .product-buy__form .shopify-product-form,
  .product-buy__form > form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: stretch;
    width: 100%;
  }

  .product-buy__options {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
  }

  .product-buy__field {
    display: grid;
    gap: 0.375rem;
    width: 100%;
    min-width: 0;
  }

  .product-buy__field--option {
    border: 0;
    margin: 0;
    padding: 0;
    min-width: 0;
  }

  .product-buy__label {
    margin-bottom: 0.625rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .product-buy__label-value {
    font-weight: 700;
  }

  .product-buy__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .product-buy__option-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .product-buy__option-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    min-height: 2.75rem;
    padding: 0.5rem 0.875rem;
    border: 1px solid color-mix(in srgb, var(--color-brand-steel) 22%, transparent);
    border-radius: var(--style-border-radius);
    background: #fff;
    color: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.2;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .product-buy__option-btn .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .product-buy__option-input:focus-visible + .product-buy__option-btn {
    outline: 2px solid var(--color-brand-rust);
    outline-offset: 2px;
  }

  .product-buy__option-input:checked + .product-buy__option-btn:not(.product-buy__option-btn--swatch) {
    border-color: var(--color-brand-steel);
    background: var(--color-brand-steel);
    color: #fff;
  }

  .product-buy__option-btn--swatch {
    width: 2.75rem;
    height: 2.75rem;
    min-width: 2.75rem;
    padding: 0;
    overflow: hidden;
    background: var(--swatch-bg, color-mix(in srgb, var(--color-brand-steel) 8%, white));
  }

  .product-buy__option-input:checked + .product-buy__option-btn--swatch {
    box-shadow:
      inset 0 0 0 2px #fff,
      inset 0 0 0 3px var(--color-brand-steel);
  }

  .product-buy__option-swatch-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-buy__option-btn--unavailable {
    opacity: 0.45;
  }

  .product-buy__availability {
    margin: 0 0 1rem;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .product-buy__sold-out .product-buy__submit {
    margin-top: 0;
  }

  .product-buy__submit {
    margin-top: 0.5rem;
    width: 100%;
  }

  .product-buy__submit .btn {
    width: 100%;
    min-height: 48px;
  }

  .product-buy__payment {
    width: 100%;
  }

  .product-buy__payment .shopify-payment-button {
    width: 100%;
  }

  .product-buy__payment shopify-accelerated-checkout {
    --shopify-accelerated-checkout-button-block-size: auto;
    --shopify-accelerated-checkout-button-border-radius: 0.25rem;
    --shopify-accelerated-checkout-button-box-shadow: none;
    width: 100%;
  }

  .product-buy__payment .shopify-payment-button__button--unbranded {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 100% !important;
    min-height: 48px !important;
    height: auto !important;
    padding: 0.75rem 1.5rem !important;
    border: 2px solid currentColor !important;
    border-radius: var(--style-border-radius) !important;
    background-color: transparent !important;
    color: inherit !important;
    font-family: var(--font-display--family) !important;
    font-size: 0.875rem !important;
    font-weight: var(--font-weight-bold, var(--font-body--weight-bold, 700)) !important;
    letter-spacing: 0.04em !important;
    line-height: 1.2 !important;
    text-align: center !important;
    text-transform: uppercase !important;
    white-space: normal !important;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease !important;
  }

  .product-buy__payment .shopify-payment-button__button--unbranded:hover:not([disabled]) {
    background-color: color-mix(in srgb, currentColor 12%, transparent) !important;
    opacity: 1 !important;
  }

  .product-buy__preorder-disclosure {
    margin: 0;
    width: 100%;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: color-mix(in srgb, currentColor 82%, transparent);
  }

  .product-buy__preorder-disclosure a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .product-buy #shopify-buyer-consent,
  .product-buy shopify-payment-terms {
    display: none !important;
  }
{% endstylesheet %}
