{% comment %}
  Cart page with AJAX line-item updates via cart-items-component.
{% endcomment %}

<h1>{{ 'cart.title' | t }}</h1>

{% render 'cart-line-items', section_id: section.id %}

{% unless cart.empty? %}
  <form action="{{ routes.cart_url }}" method="post" class="cart-page__checkout">
    <button type="submit" name="checkout">
      {{ 'cart.checkout' | t }}
    </button>
  </form>
{% endunless %}

{% stylesheet %}
  .cart-page__checkout {
    margin-top: 1.5rem;
  }

  .cart-page__checkout button {
    padding: 0.75rem 1.25rem;
    border-radius: var(--style-border-radius);
    border: none;
    background: var(--color-brand-steel);
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-weight: 600;
  }

  .cart-items {
    width: 100%;
    border-collapse: collapse;
  }

  .cart-items th,
  .cart-items td {
    padding: 0.75rem 0.5rem;
    vertical-align: top;
    text-align: left;
    border-bottom: 1px solid rgb(0 37 63 / 10%);
  }

  .cart-items__product {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .cart-items__variant {
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    opacity: 0.8;
  }

  .cart-items__quantity input {
    width: 4rem;
  }

  .cart-items__subtotal {
    margin: 1rem 0 0;
    font-weight: 700;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
