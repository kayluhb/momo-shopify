{% doc %}
  Returns a CSS class for a font scheme preset.

  @param {string} scheme - display, body, editorial, soft, bold, or uniform

  @example
  <body class="{% render 'section-font-scheme', scheme: settings.font_scheme %}">
{% enddoc %}
{% liquid
  case scheme
    when 'body'
      echo 'font-scheme-body'
    when 'editorial'
      echo 'font-scheme-editorial'
    when 'soft'
      echo 'font-scheme-soft'
    when 'bold'
      echo 'font-scheme-bold'
    when 'uniform'
      echo 'font-scheme-uniform'
    else
      echo 'font-scheme-display'
  endcase
%}
