{% liquid
  assign anchor_id = section.settings.anchor_id
  if anchor_id == blank
    assign anchor_id = section.settings.title | handleize
  endif
%}

<div
  id="{{ anchor_id }}"
  class="styleguide-label full-width"
  {{ section.shopify_attributes }}
>
  <div class="styleguide-label__inner section-inner">
    <p class="styleguide-label__eyebrow">{{ 'sections.styleguide.label_prefix' | t }}</p>
    <h2 class="styleguide-label__title">{{ section.settings.title | escape }}</h2>
  </div>
</div>

{% stylesheet %}
  .styleguide-label {
    padding-block: var(--section-padding-block-start, 2rem) var(--section-padding-block-end, 1rem);
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 12%);
    background: rgb(var(--color-background-rgb) / 60%);
  }

  .styleguide-label__inner {
    display: grid;
    gap: 0.25rem;
  }

  .styleguide-label__eyebrow {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 55%);
  }

  .styleguide-label__title {
    margin: 0;
    font-size: clamp(1.125rem, 0.5vw + 1rem, 1.375rem);
    font-weight: 600;
    line-height: 1.2;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.styleguide.label.name",
  "tag": "section",
  "class": "section-styleguide-label",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.styleguide.label.title_label",
      "default": "Section"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "t:sections.styleguide.label.anchor_label",
      "info": "t:sections.styleguide.label.anchor_info"
    }
  ],
  "presets": [
    {
      "name": "t:sections.styleguide.label.name",
      "settings": {
        "title": "Section"
      }
    }
  ]
}
{% endschema %}
