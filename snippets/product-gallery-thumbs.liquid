{% doc %}
  Renders product gallery thumbnails with optional vertical scroll arrows.

  @param {product} product - The product to display
  @param {object} [initial_media] - Initially selected media
  @param {boolean} [show_scroll_arrows] - Show up/down scroll controls on desktop
{% enddoc %}

{% if product.media.size > 1 %}
  {% if show_scroll_arrows %}
    <div class="product-gallery__thumbs-wrap" data-gallery-thumbs-wrap>
      <button
        type="button"
        class="product-gallery__thumbs-scroll product-gallery__thumbs-scroll--up"
        data-gallery-thumbs-up
        hidden
        aria-label="{{ 'products.gallery.scroll_up' | t }}"
      >
        {{ 'icon-chevron.svg' | inline_asset_content }}
      </button>
  {% endif %}

  <div
    class="product-gallery__thumbs"
    role="list"
    aria-label="{{ 'products.gallery.thumbnails' | t }}"
    {% if show_scroll_arrows %}
      data-gallery-thumbs
    {% endif %}
  >
    {% for media in product.media %}
      {% render 'product-gallery-thumb',
        product: product,
        media: media,
        initial_media: initial_media,
        index: forloop.index
      %}
    {% endfor %}
  </div>

  {% if show_scroll_arrows %}
      <button
        type="button"
        class="product-gallery__thumbs-scroll product-gallery__thumbs-scroll--down"
        data-gallery-thumbs-down
        hidden
        aria-label="{{ 'products.gallery.scroll_down' | t }}"
      >
        {{ 'icon-chevron.svg' | inline_asset_content }}
      </button>
    </div>
  {% endif %}
{% endif %}
