{% doc %}
  Horizontal collection filter and sort toolbar.

  @param {string} section_id - Section id for unique control ids
  @param {boolean} [show_in_stock_toggle] - Show in-stock-only toggle (default: true)

  @example
  {% render 'collection-toolbar', section_id: section.id %}
{% enddoc %}

{% liquid
  assign show_in_stock_toggle = show_in_stock_toggle
  if show_in_stock_toggle == nil
    assign show_in_stock_toggle = true
  endif

  assign availability_filter = nil
  for filter in collection.filters
    if filter.param_name == 'filter.v.availability'
      assign availability_filter = filter
      break
    endif
  endfor

  assign in_stock_value = nil
  if availability_filter
    for value in availability_filter.values
      if value.value == '1'
        assign in_stock_value = value
        break
      endif
    endfor
  endif
%}

<div class="collection-toolbar" role="toolbar" aria-label="{{ 'collections.toolbar_label' | t }}">
  {% if show_in_stock_toggle and in_stock_value %}
    <label class="collection-toolbar__toggle">
      <input
        type="checkbox"
        class="collection-toolbar__toggle-input"
        name="{{ in_stock_value.param_name }}"
        value="{{ in_stock_value.value }}"
        {% if in_stock_value.active %}
          checked
        {% endif %}
        {% if in_stock_value.count == 0 and in_stock_value.active == false %}
          disabled
        {% endif %}
      >
      <span class="collection-toolbar__toggle-track" aria-hidden="true"></span>
      <span class="collection-toolbar__toggle-label">{{ 'collections.in_stock_only' | t }}</span>
    </label>
  {% endif %}

  <div class="collection-toolbar__filters">
    {% for filter in collection.filters %}
      {% unless filter.param_name == 'filter.v.availability' %}
        <details class="collection-filter" {% if filter.active_values.size > 0 %}open{% endif %}>
          <summary class="collection-filter__trigger">
            <span class="collection-filter__label">{{ filter.label }}</span>
            {% if filter.active_values.size > 0 %}
              <span class="collection-filter__count">{{ filter.active_values.size }}</span>
            {% endif %}
            <span class="collection-filter__chevron" aria-hidden="true"></span>
          </summary>

          <div class="collection-filter__panel">
            {% case filter.type %}
              {% when 'list' %}
                <ul class="collection-filter__list" role="list">
                  {% for value in filter.values %}
                    <li>
                      <label class="collection-filter__option">
                        <input
                          type="checkbox"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}
                            checked
                          {% endif %}
                          {% if value.count == 0 and value.active == false %}
                            disabled
                          {% endif %}
                        >
                        <span class="collection-filter__option-label">{{ value.label }}</span>
                        <span class="collection-filter__option-count">{{ value.count }}</span>
                      </label>
                    </li>
                  {% endfor %}
                </ul>
              {% when 'boolean' %}
                <label class="collection-filter__option">
                  <input
                    type="checkbox"
                    name="{{ filter.param_name }}"
                    value="1"
                    {% if filter.true_value.active %}
                      checked
                    {% endif %}
                  >
                  <span class="collection-filter__option-label">{{ filter.label }}</span>
                </label>
              {% when 'price_range' %}
                <div class="collection-filter__price">
                  <label class="collection-filter__price-field">
                    <span>{{ 'collections.price_min' | t }}</span>
                    <input
                      type="number"
                      name="{{ filter.min_value.param_name }}"
                      {% if filter.min_value.value %}
                        value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                      {% endif %}
                      placeholder="0"
                      min="0"
                    >
                  </label>
                  <label class="collection-filter__price-field">
                    <span>{{ 'collections.price_max' | t }}</span>
                    <input
                      type="number"
                      name="{{ filter.max_value.param_name }}"
                      {% if filter.max_value.value %}
                        value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                      {% endif %}
                      placeholder="{{ filter.range_max | money_without_currency }}"
                      min="0"
                    >
                  </label>
                </div>
            {% endcase %}
          </div>
        </details>
      {% endunless %}
    {% endfor %}
  </div>

  <div class="collection-toolbar__sort">
    <label class="sr-only" for="CollectionSort-{{ section_id }}">{{ 'collections.sort_label' | t }}</label>
    <select id="CollectionSort-{{ section_id }}" class="collection-toolbar__sort-select focus-ring-brand" name="sort_by">
      {% for option in collection.sort_options %}
        <option
          value="{{ option.value }}"
          {% if option.value == collection.sort_by %}
            selected
          {% endif %}
        >
          {{ option.name }}
        </option>
      {% endfor %}
    </select>
    <span class="collection-toolbar__sort-chevron" aria-hidden="true"></span>
  </div>
</div>

{% stylesheet %}
  .collection-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
    padding: 0.875rem 1rem;
    border-radius: var(--style-border-radius);
    background: #fff;
    box-shadow: 0 1px 0 rgb(0 37 63 / 6%);
  }

  .collection-toolbar__toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    cursor: pointer;
    user-select: none;
  }

  .collection-toolbar__toggle-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .collection-toolbar__toggle-track {
    position: relative;
    flex-shrink: 0;
    width: 2.25rem;
    height: 1.25rem;
    border-radius: var(--style-border-radius);
    background: color-mix(in srgb, var(--color-brand-steel) 14%, white);
    transition: background 200ms ease;
  }

  .collection-toolbar__toggle-track::after {
    content: '';
    position: absolute;
    top: 0.125rem;
    left: 0.125rem;
    width: 1rem;
    height: 1rem;
    border-radius: var(--style-border-radius);
    background: #fff;
    box-shadow: 0 1px 2px rgb(0 37 63 / 18%);
    transition: transform 200ms ease;
  }

  .collection-toolbar__toggle-input:checked + .collection-toolbar__toggle-track {
    background: var(--color-brand-steel);
  }

  .collection-toolbar__toggle-input:checked + .collection-toolbar__toggle-track::after {
    transform: translateX(1rem);
  }

  .collection-toolbar__toggle-input:focus-visible + .collection-toolbar__toggle-track {
    outline: 2px solid var(--color-brand-rust);
    outline-offset: 2px;
  }

  .collection-toolbar__toggle-label {
    font-size: 0.875rem;
    line-height: 1.3;
    white-space: nowrap;
  }

  .collection-toolbar__filters {
    display: flex;
    flex: 1 1 auto;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .collection-filter {
    position: relative;
  }

  .collection-filter__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-brand-steel) 12%, transparent);
    border-radius: var(--style-border-radius);
    background: #fff;
    font-size: 0.875rem;
    line-height: 1.2;
    list-style: none;
    cursor: pointer;
    white-space: nowrap;
  }

  .collection-filter__trigger::-webkit-details-marker {
    display: none;
  }

  .collection-filter[open] .collection-filter__trigger {
    border-color: color-mix(in srgb, var(--color-brand-steel) 22%, transparent);
  }

  .collection-filter__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.125rem;
    height: 1.125rem;
    padding-inline: 0.25rem;
    border-radius: var(--style-border-radius);
    background: var(--color-brand-steel);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
  }

  .collection-filter__chevron,
  .collection-toolbar__sort-chevron {
    width: 0.5rem;
    height: 0.5rem;
    border-right: 1.5px solid currentcolor;
    border-bottom: 1.5px solid currentcolor;
    transform: rotate(45deg) translateY(-1px);
    opacity: 0.65;
  }

  .collection-filter__panel {
    position: absolute;
    z-index: 5;
    top: calc(100% + 0.375rem);
    left: 0;
    min-width: 12rem;
    max-width: min(18rem, 80vw);
    max-height: 16rem;
    overflow: auto;
    padding: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-brand-steel) 10%, transparent);
    border-radius: var(--style-border-radius);
    background: #fff;
    box-shadow: 0 8px 24px rgb(0 37 63 / 10%);
  }

  .collection-filter__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .collection-filter__option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.35rem;
    border-radius: var(--style-border-radius);
    font-size: 0.875rem;
    cursor: pointer;
  }

  .collection-filter__option:hover {
    background: color-mix(in srgb, var(--color-brand-steel) 5%, white);
  }

  .collection-filter__option-label {
    flex: 1 1 auto;
  }

  .collection-filter__option-count {
    color: color-mix(in srgb, var(--color-brand-steel) 55%, transparent);
    font-size: 0.8125rem;
  }

  .collection-filter__price {
    display: grid;
    gap: 0.5rem;
    padding: 0.25rem;
  }

  .collection-filter__price-field {
    display: grid;
    gap: 0.25rem;
    font-size: 0.8125rem;
  }

  .collection-filter__price-field input {
    width: 100%;
    padding: 0.4rem 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-brand-steel) 14%, transparent);
    border-radius: var(--style-border-radius);
  }

  .collection-toolbar__sort {
    position: relative;
    margin-left: auto;
    flex-shrink: 0;
  }

  .collection-toolbar__sort-select {
    appearance: none;
    padding: 0.5rem 2rem 0.5rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-brand-steel) 12%, transparent);
    border-radius: var(--style-border-radius);
    background: #fff;
    font-size: 0.875rem;
    line-height: 1.2;
    cursor: pointer;
  }

  .collection-toolbar__sort-chevron {
    position: absolute;
    top: 50%;
    right: 0.75rem;
    pointer-events: none;
    transform: rotate(45deg) translateY(-50%);
  }

  @media (max-width: 749px) {
    .collection-toolbar {
      flex-direction: column;
      align-items: stretch;
    }

    .collection-toolbar__filters {
      width: 100%;
    }

    .collection-toolbar__sort {
      width: 100%;
      margin-left: 0;
    }

    .collection-toolbar__sort-select {
      width: 100%;
    }
  }
{% endstylesheet %}
