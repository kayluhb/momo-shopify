{% doc %}
  Renders a product card for collection grids.

  @param {product} product - The product to display
  @param {string} [card_style] - Card layout: grid (default) or standard
  @param {boolean} [show_secondary_image] - Show second image on hover (default: true)
  @param {boolean} [show_color_swatches] - Show color swatches on grid cards (default: false)
  @param {boolean} [show_rating] - Show rating when metafield exists (default: false)

  @example
  {% render 'product-card', product: product %}
  {% render 'product-card', product: product, card_style: 'grid', show_color_swatches: true %}
{% enddoc %}

{% liquid
  assign card_style = card_style | default: 'standard'
  assign is_grid_card = false
  if card_style == 'grid'
    assign is_grid_card = true
  endif

  assign show_hover_image = show_secondary_image
  if show_hover_image == nil
    assign show_hover_image = true
  endif

  assign show_swatches = show_color_swatches
  if show_swatches == nil
    assign show_swatches = false
  endif

  assign show_product_rating = show_rating
  if show_product_rating == nil
    assign show_product_rating = false
  endif

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign secondary_image = product.images[1]
  if show_hover_image == false or secondary_image == blank
    assign show_hover_image = false
  endif

  assign is_new = false
  if product.tags contains 'new' or product.tags contains 'New'
    assign is_new = true
  endif

  assign rating_value = nil
  assign rating_count = nil
  if show_product_rating
    if product.metafields.reviews.rating.value != blank
      assign rating_value = product.metafields.reviews.rating.value
      assign rating_count = product.metafields.reviews.rating_count.value
    elsif product.metafields.custom.rating.value != blank
      assign rating_value = product.metafields.custom.rating.value
    endif
  endif

  assign color_option = nil
  if show_swatches
    for option in product.options_with_values
      assign option_name_down = option.name | downcase
      if option_name_down == 'color' or option_name_down == 'colour'
        assign color_option = option
        break
      endif
    endfor
  endif
%}

<article class="product-card{% if is_grid_card %} product-card--grid{% endif %}" data-product-card>
  <a class="product-card__media" href="{{ product.url }}">
    {% if product.featured_image %}
      <div class="product-card__image product-card__image--primary">
        {{
          product.featured_image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
            widths: '400,600,800',
            alt: product.featured_image.alt
            | default: product.title
        }}
      </div>
      {% if show_hover_image %}
        <div class="product-card__image product-card__image--secondary">
          {{
            secondary_image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
              widths: '400,600,800',
              alt: secondary_image.alt
              | default: product.title
          }}
        </div>
      {% endif %}
    {% else %}
      <div class="product-card__placeholder">
        {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder-svg' }}
      </div>
    {% endif %}

    {% if is_new %}
      <span class="product-card__badge product-card__badge--new">{{ 'products.badge.new' | t }}</span>
    {% elsif on_sale %}
      <span class="product-card__badge">{{ 'products.badge.sale' | t }}</span>
    {% elsif product.available == false %}
      <span class="product-card__badge product-card__badge--sold-out">{{ 'products.badge.sold_out' | t }}</span>
    {% endif %}
  </a>

  <div class="product-card__info">
    <div class="product-card__title-row">
      <h3 class="product-card__title">
        <a href="{{ product.url }}">{{ product.title | escape }}</a>
      </h3>
      {% if rating_value != blank %}
        <p class="product-card__rating" aria-label="{{ 'products.rating_label' | t: rating: rating_value, count: rating_count }}">
          <span class="product-card__rating-value">{{ rating_value }}</span>
          <span class="product-card__rating-star" aria-hidden="true">★</span>
        </p>
      {% endif %}
    </div>

    <p class="product-card__price">
      {% if on_sale %}
        <span class="product-card__price-sale">{{ product.price | money }}</span>
        <span class="sr-only">{{ 'products.price.sale' | t }}</span>
        <s class="product-card__price-compare">{{ product.compare_at_price | money }}</s>
      {% else %}
        <span>{{ product.price | money }}</span>
      {% endif %}
    </p>

    {% if color_option and color_option.values.size > 0 %}
      <ul
        class="product-card__swatches list-none p-0"
        role="list"
        aria-label="{{ 'products.color_options' | t: option: color_option.name }}"
      >
        {% for value in color_option.values %}
          {% liquid
            assign variant_for_value = value.variant
            assign option_position = color_option.position

            if variant_for_value == blank
              for variant in product.variants
                if option_position == 1
                  if variant.option1 == value.name
                    assign variant_for_value = variant
                    break
                  endif
                elsif option_position == 2
                  if variant.option2 == value.name
                    assign variant_for_value = variant
                    break
                  endif
                elsif option_position == 3
                  if variant.option3 == value.name
                    assign variant_for_value = variant
                    break
                  endif
                endif
              endfor
            endif

            assign swatch_url = product.url
            if variant_for_value
              assign swatch_url = variant_for_value.url
            endif

            assign is_selected = false
            if variant_for_value
              if variant_for_value.id == product.selected_or_first_available_variant.id
                assign is_selected = true
              endif
            endif

            assign swatch_image = nil
            if value.swatch.image != blank
              assign swatch_image = value.swatch.image
            elsif variant_for_value.featured_image
              assign swatch_image = variant_for_value.featured_image
            endif

            assign swatch_bg = ''
            if value.swatch.color != blank
              assign swatch_bg = 'rgb(' | append: value.swatch.color.rgb | append: ')'
            elsif swatch_image == blank
              assign color_key = value.name | downcase | strip
              case color_key
                when 'black'
                  assign swatch_bg = '#1a1a1a'
                when 'white'
                  assign swatch_bg = '#f5f5f5'
                when 'gray', 'grey'
                  assign swatch_bg = '#9ca3af'
                when 'navy', 'blue'
                  assign swatch_bg = '#1e3a5f'
                when 'red'
                  assign swatch_bg = '#c0392b'
                when 'green'
                  assign swatch_bg = '#2d6a4f'
                when 'yellow'
                  assign swatch_bg = '#f4d03f'
                when 'pink'
                  assign swatch_bg = '#f4a6b8'
                when 'brown'
                  assign swatch_bg = '#8b5e3c'
                when 'orange'
                  assign swatch_bg = '#e67e22'
                when 'purple'
                  assign swatch_bg = '#6c4f8a'
                when 'beige', 'tan'
                  assign swatch_bg = '#d4b896'
              endcase
            endif

            assign preview_image_url = ''
            if variant_for_value.featured_image
              assign preview_image_url = variant_for_value.featured_image | image_url: width: 800
            endif
          %}
          <li>
            <a
              href="{{ swatch_url }}"
              class="product-card__swatch{% if is_selected %} is-selected{% endif %}"
              {% if swatch_bg != blank %}
                style="--swatch-bg: {{ swatch_bg }};"
              {% endif %}
              {% if preview_image_url != blank %}
                data-swatch-image="{{ preview_image_url }}"
              {% endif %}
              aria-label="{{ value.name | escape }}"
              {% if is_selected %}
                aria-current="true"
              {% endif %}
            >
              {% if swatch_image %}
                {{
                  swatch_image
                  | image_url: width: 80, height: 80, crop: 'center'
                  | image_tag:
                    class: 'product-card__swatch-img',
                    loading: 'lazy',
                    widths: '40, 80',
                    sizes: '16px',
                    alt: ''
                }}
              {% endif %}
            </a>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</article>

{% stylesheet %}
  .product-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .product-card--grid {
    gap: 0;
    height: 100%;
    border-radius: 0.5rem;
    background: #fff;
    overflow: hidden;
    box-shadow: 0 1px 0 rgb(0 37 63 / 6%);
    transition: box-shadow 200ms ease, transform 200ms ease;
  }

  .product-card--grid:hover {
    box-shadow: 0 8px 24px rgb(0 37 63 / 8%);
    transform: translateY(-1px);
  }

  .product-card__media {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
  }

  .product-card--grid .product-card__media {
    aspect-ratio: 1 / 1;
    background: #fff;
  }

  .product-card:not(.product-card--grid) .product-card__media {
    border-radius: 0.5rem;
    aspect-ratio: 4 / 5;
    background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
  }

  .product-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .product-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-card--grid .product-card__image img {
    object-fit: contain;
    padding: 1rem;
  }

  .product-card__image--secondary {
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .product-card__media:hover .product-card__image--secondary {
      opacity: 1;
    }
  }

  .product-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .product-card__placeholder-svg {
    width: 60%;
    height: auto;
    opacity: 0.35;
  }

  .product-card__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1;
    padding: 0.25rem 0.5rem;
    border-radius: 9999px;
    background-color: var(--color-brand-heart, #ff5e6e);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .product-card__badge--new {
    background-color: var(--color-brand-steel, #00253f);
  }

  .product-card__badge--sold-out {
    background-color: var(--color-foreground);
  }

  .product-card--grid .product-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.875rem 1rem 1rem;
  }

  .product-card__title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .product-card__title {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.35;
  }

  .product-card--grid .product-card__title {
    font-size: 0.875rem;
    line-height: 1.3;
  }

  .product-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .product-card__title a:hover {
    color: var(--color-brand-rust);
  }

  .product-card__rating {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    margin: 0;
    flex-shrink: 0;
    font-size: 0.8125rem;
    line-height: 1;
    white-space: nowrap;
  }

  .product-card__rating-value {
    font-weight: 700;
  }

  .product-card__rating-star {
    color: #f5b301;
    font-size: 0.75rem;
  }

  .product-card__price {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.4;
    color: color-mix(in srgb, var(--color-brand-steel, #00253f) 72%, transparent);
  }

  .product-card--grid .product-card__price {
    font-size: 0.8125rem;
  }

  .product-card__price-sale {
    color: var(--color-brand-heart, #ff5e6e);
  }

  .product-card__price-compare {
    margin-left: 0.35rem;
    color: color-mix(in srgb, var(--color-brand-steel, #00253f) 65%, transparent);
  }

  .product-card__swatches {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    margin: 0.25rem 0 0;
  }

  .product-card__swatch {
    position: relative;
    display: block;
    overflow: hidden;
    width: 1rem;
    height: 1rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--color-brand-steel, #00253f) 18%, transparent);
    background-color: var(--swatch-bg, color-mix(in srgb, var(--color-brand-steel, #00253f) 8%, white));
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    cursor: pointer;
    text-decoration: none;
    transition: box-shadow 150ms ease, transform 150ms ease;
  }

  .product-card__swatch:hover {
    transform: scale(1.08);
  }

  .product-card__swatch:focus-visible {
    outline: 2px solid var(--color-brand-rust, #c57639);
    outline-offset: 2px;
  }

  .product-card__swatch.is-selected {
    box-shadow: 0 0 0 1px #fff, 0 0 0 2px var(--color-brand-steel, #00253f);
  }

  .product-card__swatch-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }
{% endstylesheet %}

