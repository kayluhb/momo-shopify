{% doc %}
  Global CSS custom properties, including typography and layout spacing.

  Layout spacing:
  - `--page-margin`: desktop horizontal gutter (from theme settings)
  - `--page-margin-mobile`: mobile horizontal gutter (from theme settings)
  - `--grid-gap` / `--grid-gap-mobile`: grid spacing (from theme settings)
  - `--section-padding-block` / `--section-padding-block-mobile`: vertical section spacing
  - `--grid-gap-active` / `--section-padding-block-active`: responsive values (set in critical.css)

  @example
  {% render 'css-variables' %}
{% enddoc %}
{% style %}
  :root {
    --font-display--family: "degular-display-thin", "degular-display", sans-serif;
    --font-body--family: var(--font-display--family);
    --font-display--weight: 400;
    --font-display--weight-bold: 700;
    --font-body--weight: 400;
    --font-body--weight-bold: 700;
    --font-brand--family: var(--font-display--family);
    --font-weight-normal: 400;
    --font-weight-medium: 400;
    --font-weight-bold: 700;
    --page-width: 90rem;
    --page-margin: {{ settings.min_page_margin | default: 20 }}px;
    --page-margin-mobile: {{ settings.min_page_margin_mobile | default: 12 }}px;
    --grid-gap: {{ settings.grid_gap | default: 12 }}px;
    --grid-gap-mobile: {{ settings.grid_gap_mobile | default: 12 }}px;
    --section-padding-block: {{ settings.section_padding | default: 80 }}px;
    --section-padding-block-mobile: {{ settings.section_padding_mobile | default: 32 }}px;
    --drawer-width: min(28rem, 100vw);
    --header-padding-y: 2rem;
    --header-padding-y-scrolled: 0.75rem;
    --header-logo-max-height: 2.5rem;
    --header-logo-max-height-scrolled: 1.375rem;
    --header-icon-size: 1.625rem;
    --header-icon-size-scrolled: 1.375rem;
    --header-icon-scale-scrolled: calc(var(--header-icon-size-scrolled) / var(--header-icon-size));
    --header-height: calc(var(--header-padding-y) * 2 + var(--header-logo-max-height));
    --header-height-scrolled: calc(
      var(--header-padding-y-scrolled) * 2 +
        max(var(--header-logo-max-height-scrolled), var(--header-icon-size-scrolled))
    );
    --header-shrink-scroll-range: 96;
    --header-scroll-progress: 0;
    --section-header-eyebrow-gap: var(--section-heading-eyebrow-margin-bottom, 0.375rem);
    --section-header-title-gap: var(--section-heading-title-margin-bottom, 0.375rem);
    --section-header-stack-gap: var(--section-heading-stack-margin-bottom, 2.75rem);
    --type-eyebrow-margin-bottom: 0.375rem;
    --heading-margin-bottom: 0.5rem;
    --body-paragraph-margin-bottom: 1rem;
    --hero-eyebrow-margin-bottom: 0.375rem;
    --hero-heading-margin-bottom: 0.375rem;
    --hero-subheading-margin-bottom: 1.5rem;
    --section-heading-eyebrow-margin-bottom: 0.375rem;
    --section-heading-title-margin-bottom: 0.375rem;
    --section-heading-stack-margin-bottom: 2.75rem;
    --promo-heading-margin-bottom: 0.375rem;
    --page-heading-margin-bottom: 1.5rem;
    --product-title-margin-bottom: 0.5rem;
    --collection-hero-heading-margin-bottom: 0.5rem;
    --about-headline-margin-bottom: 0;
    --announcement-bar-height: calc(2.25rem + 0.875rem);
    --header-offset: calc(var(--header-height) + var(--announcement-bar-height));
    --header-offset-scrolled: calc(var(--header-height-scrolled) + var(--announcement-bar-height));
    --color-background: #ffffff;
    --color-foreground: #333333;
    --color-selection-background: #00253f;
    --color-selection-foreground: #ffffff;
    --style-border-radius: 0.25rem;
    --style-border-radius-inputs: var(--style-border-radius);
    --style-border-radius-sm: var(--style-border-radius);
  }
{% endstyle %}
