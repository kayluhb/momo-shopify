<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% render 'dark-scheme-overrides' %}

    {% render 'degular-fonts' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% render 'section-font-scheme-styles' %}

    {% # Tailwind utilities (build: pnpm run css:build in shopify/) %}
    {{ 'tailwind.css' | asset_url | stylesheet_tag }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {% render 'scripts' %}

    {{ content_for_header }}
  </head>

  <body class="template-{{ template.name | handle }} {% render 'section-font-scheme', scheme: settings.font_scheme %}">
    {% render 'skip-to-main' %}

    {% sections 'header-group' %}

    <main id="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% section 'cart-drawer' %}
  </body>
</html>
