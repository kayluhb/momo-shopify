{% liquid
  assign hero_image = section.settings.image
  if hero_image == blank
    assign hero_image = collection.image
  endif

  assign hero_heading = section.settings.heading
  if hero_heading == blank
    assign hero_heading = collection.title
  endif

  assign hero_description = section.settings.description
  if hero_description == blank
    assign hero_description = collection.description
  endif

  assign featured_product = section.settings.featured_product
  if featured_product == blank and collection.products_count > 0
    assign featured_product = collection.products.first
  endif

  assign overlay_opacity = section.settings.overlay_opacity
  if overlay_opacity == blank
    assign overlay_opacity = 40
  endif

  if hero_image != blank
    if hero_image.alt != blank
      assign hero_alt = hero_image.alt
    else
      assign hero_alt = hero_heading
    endif
  endif
%}

<div
  class="collection-hero hero hero--parallax full-width"
  data-hero-parallax
  data-collection-hero
  style="--collection-hero-height: {{ section.settings.hero_height }}vh;"
  {{ section.shopify_attributes }}
>
  <div class="collection-hero__media hero__media">
    {% if hero_image != blank %}
      <div class="hero__parallax" data-hero-parallax-media>
        {{
          hero_image
          | image_url: width: 3840
          | image_tag:
            widths: '550, 720, 990, 1100, 1500, 2200, 3000, 3840',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'hero__img hero__img--parallax',
            alt: hero_alt
        }}
      </div>
    {% else %}
      <div class="collection-hero__placeholder" aria-hidden="true">
        {{ 'collection-1' | placeholder_svg_tag: class: 'hero__img hero__img--placeholder' }}
      </div>
    {% endif %}
    <div
      class="hero__overlay"
      style="background: rgb(0 0 0 / {{ overlay_opacity }}%);"
      aria-hidden="true"
    ></div>
  </div>

  <div class="collection-hero__content">
    <div class="collection-hero__copy">
      <h1 class="collection-hero__heading">{{ hero_heading | escape }}</h1>
      {% if hero_description != blank %}
        <div class="collection-hero__description rte">
          {{ hero_description }}
        </div>
      {% endif %}
    </div>

    {% if featured_product != blank and section.settings.show_featured_product %}
      <aside class="collection-hero__featured">
        <p class="collection-hero__featured-label">{{ 'sections.collection_hero.featured_product' | t }}</p>
        <a class="collection-hero__featured-card" href="{{ featured_product.url }}">
          {% if featured_product.featured_image %}
            <div class="collection-hero__featured-media">
              {{
                featured_product.featured_image
                | image_url: width: 160, height: 160, crop: 'center'
                | image_tag:
                  widths: '80, 120, 160',
                  sizes: '80px',
                  loading: 'lazy',
                  class: 'collection-hero__featured-image',
                  alt: featured_product.featured_image.alt | default: featured_product.title
              }}
            </div>
          {% endif %}
          <div class="collection-hero__featured-details">
            <p class="collection-hero__featured-title">{{ featured_product.title | escape }}</p>
            <p class="collection-hero__featured-price">{{ featured_product.price | money }}</p>
          </div>
        </a>
      </aside>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .collection-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: var(--collection-hero-height, 45vh);
    overflow: hidden;
  }

  .collection-hero .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .collection-hero__placeholder {
    position: absolute;
    inset: 0;
    background: rgb(30 30 30);
  }

  .collection-hero__placeholder .hero__img--placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
  }

  .collection-hero .hero__parallax {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .collection-hero .hero__img {
    position: relative;
    z-index: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
  }

  .collection-hero.hero--parallax .hero__img--parallax {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 118%;
    max-width: none;
    object-fit: cover;
    object-position: center;
    transform: translate3d(0, calc(-50% + var(--hero-parallax-y, 0px)), 0);
    will-change: transform;
  }

  .collection-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem 2rem;
    width: 100%;
    max-width: min(calc(var(--page-width) - var(--page-margin) * 2), calc(100% - var(--page-margin) * 2));
    margin-inline: auto;
    padding: calc(var(--header-height) + 2.5rem) var(--page-margin) clamp(2rem, 4vw, 3rem);
    color: #fff;
  }

  .collection-hero__copy {
    flex: 1 1 16rem;
    max-width: 42rem;
  }

  .collection-hero__heading {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4vw + 0.75rem, 3.25rem);
    line-height: 1.05;
    font-weight: 700;
  }

  .collection-hero__description {
    margin: 0;
    max-width: 36rem;
    font-size: clamp(0.9375rem, 0.5vw + 0.85rem, 1.125rem);
    line-height: 1.55;
    color: rgb(255 255 255 / 88%);
  }

  .collection-hero__description p {
    margin: 0;
  }

  .collection-hero__description p + p {
    margin-top: 0.75rem;
  }

  .collection-hero__featured {
    flex: 0 1 20rem;
    width: min(100%, 20rem);
    margin-left: auto;
  }

  .collection-hero__featured-label {
    margin: 0 0 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: right;
    color: rgb(255 255 255 / 72%);
  }

  .collection-hero__featured-card {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 0.875rem;
    align-items: center;
    padding: 0.875rem;
    border-radius: 0.25rem;
    background: rgb(0 0 0 / 42%);
    color: #fff;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background 200ms ease, transform 200ms ease;
  }

  .collection-hero__featured-card:hover {
    background: rgb(0 0 0 / 54%);
    transform: translateY(-1px);
  }

  .collection-hero__featured-card:focus-visible {
    outline: 2px solid rgb(255 255 255 / 70%);
    outline-offset: 3px;
  }

  .collection-hero__featured-media {
    overflow: hidden;
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 0.125rem;
    background: rgb(255 255 255 / 8%);
  }

  .collection-hero__featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-hero__featured-title {
    margin: 0 0 0.25rem;
    font-size: 0.9375rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .collection-hero__featured-price {
    margin: 0;
    font-size: 0.875rem;
    color: rgb(255 255 255 / 78%);
  }

  @media (max-width: 47.99rem) {
    .collection-hero__content {
      flex-direction: column;
      align-items: stretch;
    }

    .collection-hero__featured {
      width: 100%;
      margin-left: 0;
    }

    .collection-hero__featured-label {
      text-align: left;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-hero.hero--parallax .hero__img--parallax {
      position: relative;
      top: auto;
      left: auto;
      height: 100%;
      transform: none;
      will-change: auto;
    }
  }
{% endstylesheet %}

{% render 'hero-parallax' %}

{% schema %}
{
  "name": "t:sections.collection_hero.name",
  "tag": "section",
  "class": "section-collection-hero",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.collection_hero.settings.image_label",
      "info": "t:sections.collection_hero.settings.image_info"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "t:sections.collection_hero.settings.overlay_opacity_label",
      "default": 40
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "vh",
      "label": "t:sections.collection_hero.settings.hero_height_label",
      "default": 45
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collection_hero.settings.heading_label",
      "info": "t:sections.collection_hero.settings.heading_info"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.collection_hero.settings.description_label",
      "info": "t:sections.collection_hero.settings.description_info"
    },
    {
      "type": "checkbox",
      "id": "show_featured_product",
      "label": "t:sections.collection_hero.settings.show_featured_product_label",
      "default": true
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "t:sections.collection_hero.settings.featured_product_label",
      "info": "t:sections.collection_hero.settings.featured_product_info"
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection_hero.presets.default_name"
    }
  ]
}
{% endschema %}
