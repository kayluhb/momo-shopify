{% liquid
  assign scheme = section.settings.color_scheme
  assign use_gradient = section.settings.use_gradient

  case scheme
    when 'heart'
      assign section_bg = 'bg-brand-heart text-white'
    when 'warmth'
      assign section_bg = 'bg-brand-warmth text-white'
    when 'steel'
      assign section_bg = 'bg-brand-steel text-white'
    when 'earth'
      assign section_bg = 'bg-brand-earth text-white'
    else
      assign section_bg = 'bg-brand-steel text-white'
  endcase

  if use_gradient
    assign section_bg = section_bg | append: ' promo-banner--gradient'
  endif
%}

<section
  id="shopify-section-{{ section.id }}"
  class="promo-banner full-width {{ section_bg }}"
>
  {% if section.settings.background_image != blank %}
    <div class="promo-banner__bg" aria-hidden="true">
      {{
        section.settings.background_image
        | image_url: width: 2000
        | image_tag: loading: 'lazy', sizes: '100vw', widths: '800,1200,1600,2000', class: 'promo-banner__bg-img'
      }}
      <span class="promo-banner__overlay" style="--overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></span>
    </div>
  {% endif %}

  <div class="section-inner promo-banner__inner">
    <div class="promo-banner__content">
      {% if section.settings.heading != blank %}
        <h2 class="promo-banner__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="promo-banner__text">{{ section.settings.text | escape }}</p>
      {% endif %}
    </div>

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      {% render 'button',
        label: section.settings.button_label,
        url: section.settings.button_link,
        style: 'secondary',
        class: 'promo-banner__btn'
      %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .promo-banner {
    position: relative;
    overflow: hidden;
    padding: 2.5rem 0;
  }

  .promo-banner--gradient {
    background-image: linear-gradient(
      135deg,
      var(--color-brand-steel, #00253f) 0%,
      var(--color-brand-earth, #987659) 100%
    );
  }

  .promo-banner__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .promo-banner__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .promo-banner__overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / var(--overlay, 0.4));
  }

  .promo-banner__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .promo-banner__content {
    flex: 1 1 16rem;
    min-width: 0;
  }

  .promo-banner__heading {
    margin: 0 0 0.35rem;
    font-size: clamp(1.375rem, 2.5vw, 1.875rem);
    line-height: 1.12;
  }

  .promo-banner__text {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.5;
    opacity: 0.9;
  }

  .promo-banner__btn.btn--secondary {
    border-color: #fff;
    color: #fff;
    flex-shrink: 0;
  }

  .promo-banner__btn.btn--secondary:hover {
    background: rgb(255 255 255 / 12%);
    opacity: 1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.promo_banner.name",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.shared.content_header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.shared.heading_label",
      "default": "Free shipping on orders over $100"
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:sections.shared.text_label"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.shared.button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.shared.button_link_label"
    },
    {
      "type": "header",
      "content": "t:sections.shared.appearance_header"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme_label",
      "default": "steel",
      "options": [
        { "value": "steel", "label": "t:options.color_scheme.steel" },
        { "value": "earth", "label": "t:options.color_scheme.earth" },
        { "value": "warmth", "label": "t:options.color_scheme.warmth" },
        { "value": "heart", "label": "t:options.color_scheme.heart" }
      ]
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "t:sections.promo_banner.use_gradient_label",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.promo_banner.background_image_label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.promo_banner.overlay_opacity_label",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:sections.promo_banner.presets.default_name",
      "settings": {
        "heading": "Free shipping on orders over $100",
        "button_label": "Shop now",
        "button_link": "shopify://collections/all",
        "color_scheme": "steel"
      }
    }
  ]
}
{% endschema %}
