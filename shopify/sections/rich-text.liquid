{% liquid
  assign text_align = section.settings.text_alignment
  assign use_gradient = section.settings.use_gradient
%}
{% capture section_bg %}{% render 'section-color-scheme', scheme: section.settings.color_scheme %}{% endcapture %}
{% if use_gradient %}
  {% assign section_bg = section_bg | append: ' rich-text--gradient' %}
{% endif %}

<section
  id="shopify-section-{{ section.id }}"
  class="rich-text full-width py-14 md:py-20 {{ section_bg }}"
>
  <div class="section-inner rich-text__inner rich-text__inner--{{ text_align }}">
    {% if section.settings.eyebrow != blank %}
      <p class="rich-text__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="rich-text__heading{% if section.settings.display_size %} rich-text__heading--display{% endif %}">
        {{ section.settings.heading | escape }}
      </h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="rich-text__body rte">{{ section.settings.text }}</div>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <div class="rich-text__cta">
        {% render 'button',
          label: section.settings.button_label,
          url: section.settings.button_link,
          style: section.settings.button_style
        %}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .rich-text--gradient {
    background-image: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-brand-steel, #00253f) 6%, transparent) 0%,
      transparent 100%
    );
  }

  .rich-text__inner {
    max-width: 42rem;
  }

  .rich-text__inner--center {
    margin-inline: auto;
    text-align: center;
  }

  .rich-text__inner--center .rich-text__cta {
    justify-content: center;
  }

  .rich-text__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-rust, #c57639);
  }

  :where(.bg-brand-earth, .bg-brand-steel, .bg-brand-warmth, .bg-brand-heart) .rich-text__eyebrow {
    color: var(--color-brand-warmth, #ea7657);
  }

  .rich-text__heading {
    margin: 0 0 1.25rem;
    font-family: var(--font-display--family, var(--font-primary--family));
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 400;
    line-height: 1.15;
  }

  .rich-text__heading--display {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    line-height: 1.05;
  }

  .rich-text__body {
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .rich-text__body :where(p) {
    margin: 0 0 1rem;
  }

  .rich-text__body :where(p:last-child) {
    margin-bottom: 0;
  }

  .rich-text__cta {
    display: flex;
    margin-top: 2rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.rich_text.name",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.shared.content_header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.shared.eyebrow_label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.shared.heading_label",
      "default": "Designed to endure"
    },
    {
      "type": "checkbox",
      "id": "display_size",
      "label": "t:sections.rich_text.display_size_label",
      "default": true
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.shared.text_label",
      "default": "<p>We believe in objects that earn their place — pieces shaped by material honesty, refined proportion, and the quiet confidence of lasting craft.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.shared.button_label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.shared.button_link_label"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:sections.shared.button_style_label",
      "default": "primary",
      "options": [
        { "value": "primary", "label": "t:options.button_style.primary" },
        { "value": "secondary", "label": "t:options.button_style.secondary" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:sections.shared.heading_alignment_label",
      "default": "center",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.shared.appearance_header"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme_label",
      "default": "white",
      "options": [
        { "value": "white", "label": "t:options.color_scheme.white" },
        { "value": "canvas", "label": "t:options.color_scheme.canvas" },
        { "value": "earth", "label": "t:options.color_scheme.earth" },
        { "value": "steel", "label": "t:options.color_scheme.steel" }
      ]
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "t:sections.rich_text.use_gradient_label",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "t:sections.rich_text.presets.default_name",
      "settings": {
        "heading": "Designed to endure",
        "display_size": true,
        "text": "<p>We believe in objects that earn their place — pieces shaped by material honesty, refined proportion, and the quiet confidence of lasting craft.</p>",
        "text_alignment": "center",
        "color_scheme": "white"
      }
    }
  ]
}
{% endschema %}
