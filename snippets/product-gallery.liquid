{% doc %}
  Renders a product media gallery with a large main stage and optional thumbnails.

  @param {product} product - The product to display
  @param {string} layout - split, split_tall, split_half, or hero
  @param {string} section_id - Section ID for unique element IDs
  @param {number} [hero_height] - Hero band height in rem when layout is hero
  @param {number} [overlay_opacity] - Hero overlay opacity percentage
{% enddoc %}

{% liquid
  assign gallery_layout = layout | default: 'split'
  assign current_variant = product.selected_or_first_available_variant
  assign initial_media = current_variant.featured_media | default: product.featured_media

  if gallery_layout == 'hero'
    assign image_sizes = '100vw'
    assign image_widths = '600, 900, 1200, 1600, 2000, 2400, 3000, 3840'
    assign max_image_width = 3840
    assign carousel_eager_all = true
    assign carousel_video_size = '2048x'
  else
    assign image_sizes = '(min-width: 990px) 50vw, 100vw'
    assign image_widths = '600, 900, 1200, 1600, 2000, 2400'
    assign max_image_width = 2400
    assign carousel_eager_all = false
    assign carousel_video_size = '1600x'
  endif

  if hero_height == blank
    assign hero_height = 42
  endif

  if overlay_opacity == blank
    assign overlay_opacity = 35
  endif

  assign has_image_media = false
  for media in product.media
    if media.media_type == 'image'
      assign has_image_media = true
      break
    endif
  endfor
%}

<product-gallery
  class="product-gallery product-gallery--{{ gallery_layout }}"
  data-layout="{{ gallery_layout }}"
  data-section-id="{{ section_id }}"
  {% if initial_media %}
    data-initial-media-id="{{ initial_media.id }}"
  {% endif %}
>
  {% if gallery_layout == 'hero' %}
    <div
      class="product-gallery__hero"
      style="--product-gallery-hero-height: {{ hero_height }}rem;"
    >
      <div class="product-gallery__hero-media" data-gallery-zoom>
        {% render 'product-gallery-carousel',
          product: product,
          initial_media: initial_media,
          eager_all: carousel_eager_all,
          max_image_width: max_image_width,
          image_widths: image_widths,
          image_sizes: image_sizes,
          video_image_size: carousel_video_size
        %}
        {% if has_image_media %}
          {% render 'product-gallery-zoom-button', initial_media: initial_media %}
        {% endif %}
        <div
          class="product-gallery__overlay"
          style="background: rgb(0 0 0 / {{ overlay_opacity }}%);"
          aria-hidden="true"
        ></div>
      </div>
    </div>
    {% render 'product-gallery-thumbs', product: product, initial_media: initial_media %}
  {% elsif gallery_layout == 'split_half' %}
    <div
      class="product-gallery__stack"
      data-gallery-mobile-track
      data-gallery-zoom
      tabindex="0"
      aria-roledescription="carousel"
      aria-label="{{ 'products.gallery.pagination' | t }}"
    >
      {% render 'product-gallery-stack',
        product: product,
        max_image_width: max_image_width,
        image_widths: image_widths,
        image_sizes: image_sizes
      %}
    </div>

    {% if product.media.size > 1 %}
      <div
        class="product-gallery__dots"
        data-gallery-dots
        role="tablist"
        aria-label="{{ 'products.gallery.pagination' | t }}"
      >
        {% for media in product.media %}
          <button
            type="button"
            class="product-gallery__dot{% if forloop.first %} is-active{% endif %}"
            data-gallery-dot
            data-slide-index="{{ forloop.index0 }}"
            role="tab"
            aria-label="{{ 'products.gallery.go_to_slide' | t: index: forloop.index, count: product.media.size }}"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  {% else %}
    <div class="product-gallery__layout">
      <div class="product-gallery__stage" data-gallery-zoom>
        {% render 'product-gallery-carousel',
          product: product,
          initial_media: initial_media,
          eager_all: carousel_eager_all,
          max_image_width: max_image_width,
          image_widths: image_widths,
          image_sizes: image_sizes,
          video_image_size: carousel_video_size
        %}
        {% if has_image_media %}
          {% render 'product-gallery-zoom-button', initial_media: initial_media %}
        {% endif %}
      </div>
      {% render 'product-gallery-thumbs',
        product: product,
        initial_media: initial_media,
        show_scroll_arrows: true
      %}
    </div>
  {% endif %}
</product-gallery>

{% stylesheet %}
  .product-gallery {
    --product-gallery-thumb-size: 4rem;
    --product-gallery-thumb-gap: 0.5rem;
    --product-gallery-thumb-max-visible: 9;

    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .product-gallery__layout {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  @media (min-width: 750px) {
    .product-gallery__layout {
      flex-direction: row;
      align-items: stretch;
    }

    .product-gallery__layout .product-gallery__stage {
      flex: 1;
      min-width: 0;
    }

    .product-gallery__layout .product-gallery__thumbs-wrap {
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      align-self: flex-start;
      order: -1;
      gap: 0.25rem;
      width: var(--product-gallery-thumb-size);
    }

    .product-gallery__layout .product-gallery__thumbs {
      flex-direction: column;
      flex-wrap: nowrap;
      max-height: calc(
        var(--product-gallery-thumb-max-visible) * var(--product-gallery-thumb-size) +
          (var(--product-gallery-thumb-max-visible) - 1) * var(--product-gallery-thumb-gap)
      );
      min-height: 0;
      overflow-x: hidden;
      overflow-y: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .product-gallery__layout .product-gallery__thumbs::-webkit-scrollbar {
      display: none;
    }

    .product-gallery__layout .product-gallery__thumbs-wrap--scrollable .product-gallery__thumbs-scroll {
      display: flex;
    }
  }

  .product-gallery__stage {
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
    aspect-ratio: 4 / 5;
    background-color: color-mix(in srgb, currentColor 8%, transparent);
  }

  .product-gallery__zoom-link {
    display: block;
    width: 100%;
    height: 100%;
    color: inherit;
    text-decoration: none;
    cursor: zoom-in;
  }

  .product-gallery__zoom {
    position: absolute;
    right: 0.75rem;
    bottom: 0.75rem;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-background, #fff) 88%, transparent);
    color: currentcolor;
    cursor: pointer;
    backdrop-filter: blur(8px);
  }

  .product-gallery__zoom svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  .product-gallery__zoom:hover {
    border-color: var(--color-brand-rust, #c57639);
    color: var(--color-brand-rust, #c57639);
  }

  .product-gallery__zoom:focus-visible {
    outline: 2px solid var(--color-brand-rust, #c57639);
    outline-offset: 2px;
  }

  .product-gallery__zoom:disabled,
  .product-gallery__zoom[hidden] {
    display: none;
  }

  .product-gallery--hero .product-gallery__zoom {
    z-index: 3;
  }

  .product-gallery--split_tall .product-gallery__stage {
    aspect-ratio: auto;
    min-height: calc(100svh - var(--header-height, 0px) - var(--announcement-bar-height, 0px) - 8rem);
  }

  .product-gallery--split_half {
    min-width: 0;
  }

  .product-gallery__stack {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  .product-gallery__stack-item {
    position: relative;
    width: 100%;
    background-color: color-mix(in srgb, currentColor 8%, transparent);
  }

  .product-gallery--split_half .product-gallery__stack-item .product-gallery__zoom-link,
  .product-gallery--split_half .product-gallery__stack-item .product-gallery__media-tag {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: auto;
    object-fit: cover;
  }

  .product-gallery--split_half .product-gallery__stack-item .product-gallery__img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .product-gallery--split_half .product-gallery__placeholder {
    min-height: 50svh;
  }

  @media (max-width: 989px) {
    .product-gallery--split_half .product-gallery__stack {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: 100%;
      gap: 0;
      width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .product-gallery--split_half .product-gallery__stack::-webkit-scrollbar {
      display: none;
    }

    .product-gallery--split_half .product-gallery__stack-item {
      width: auto;
      min-width: 0;
      overflow: hidden;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      background-color: transparent;
    }

    .product-gallery--split_half .product-gallery__stack-item .product-gallery__zoom-link,
    .product-gallery--split_half .product-gallery__stack-item .product-gallery__media-tag {
      width: 100%;
      height: auto;
      aspect-ratio: 4 / 5;
      overflow: hidden;
    }

    .product-gallery--split_half .product-gallery__stack-item .product-gallery__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .product-gallery--split_half .product-gallery__placeholder {
      width: 100%;
      aspect-ratio: 4 / 5;
      min-height: 0;
    }

    .product-gallery--split_half .product-gallery__stack:focus-visible {
      outline: 2px solid var(--color-brand-rust, #c57639);
      outline-offset: -2px;
    }

    .product-gallery--split_half .product-gallery__dots {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.75rem var(--page-margin);
    }
  }

  .product-gallery__dots {
    display: none;
  }

  .product-gallery__dot {
    width: 0.5rem;
    height: 0.5rem;
    padding: 0;
    border: none;
    border-radius: 999px;
    background-color: color-mix(in srgb, currentColor 28%, transparent);
    cursor: pointer;
  }

  .product-gallery__dot.is-active {
    background-color: var(--color-brand-rust, #c57639);
  }

  .product-gallery__dot:focus-visible {
    outline: 2px solid var(--color-brand-rust, #c57639);
    outline-offset: 2px;
  }

  .product-gallery__panel {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-gallery__panel.is-active {
    z-index: 1;
  }

  .product-gallery__panel[hidden] {
    display: none !important;
  }

  .product-gallery__img,
  .product-gallery__media-tag {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-gallery__media-tag {
    display: block;
  }

  .product-gallery__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    min-height: 16rem;
  }

  .product-gallery__img--placeholder {
    width: 60%;
    height: auto;
    opacity: 0.35;
    object-fit: contain;
  }

  .product-gallery__thumbs-wrap {
    display: contents;
  }

  .product-gallery__thumbs-scroll {
    display: none;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 1.5rem;
    padding: 0;
    border: 0;
    border-radius: 0.25rem;
    background: color-mix(in srgb, var(--color-background, #fff) 92%, transparent);
    color: currentcolor;
    cursor: pointer;
  }

  .product-gallery__thumbs-scroll svg {
    width: 1rem;
    height: 1rem;
  }

  .product-gallery__thumbs-scroll--down svg {
    transform: rotate(180deg);
  }

  .product-gallery__thumbs-scroll:hover {
    color: var(--color-brand-rust, #c57639);
  }

  .product-gallery__thumbs-scroll:focus-visible {
    outline: 2px solid var(--color-brand-rust, #c57639);
    outline-offset: 2px;
  }

  .product-gallery__thumbs-scroll[hidden] {
    display: none !important;
  }

  .product-gallery__thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--product-gallery-thumb-gap);
  }

  .product-gallery__thumb {
    flex-shrink: 0;
    width: var(--product-gallery-thumb-size);
    height: var(--product-gallery-thumb-size);
    padding: 0;
    overflow: hidden;
    border: 2px solid transparent;
    border-radius: 0.25rem;
    background: color-mix(in srgb, currentColor 6%, transparent);
    cursor: pointer;
  }

  .product-gallery__thumb.is-active {
    border-color: var(--color-brand-rust, #c57639);
  }

  .product-gallery__thumb:focus-visible {
    outline: 2px solid var(--color-brand-rust, #c57639);
    outline-offset: 2px;
  }

  .product-gallery__thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .product-gallery__thumb:hover .product-gallery__thumb-img {
    transform: scale(1.03);
  }

  .product-gallery--hero {
    gap: 0;
    width: 100%;
  }

  .product-gallery__hero {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: var(--product-gallery-hero-height, 42rem);
    min-height: 0;
  }

  .product-gallery__hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .product-gallery--hero .product-gallery__panel {
    position: absolute;
    inset: 0;
  }

  .product-gallery--hero .product-gallery__panel.is-active {
    position: absolute;
    inset: 0;
  }

  .product-gallery__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .product-gallery--hero .product-gallery__thumbs {
    position: relative;
    z-index: 2;
    margin-top: -3.5rem;
    padding-inline: var(--page-margin);
    padding-bottom: 0.75rem;
  }
{% endstylesheet %}
