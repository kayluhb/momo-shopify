{% doc %}
  Renders an accessible skip link as the first focusable element on the page.

  @example
  {% render 'skip-to-main' %}
{% enddoc %}

<a href="#main" class="skip-to-main">
  {{ 'general.accessibility.skip_to_main' | t }}
</a>

{% stylesheet %}
  .skip-to-main {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 10000;
    padding: 0.75rem 1rem;
    background-color: var(--color-brand-primary, #00253f);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transform: translateY(-120%);
    transition: transform 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .skip-to-main:focus {
    transform: translateY(0);
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .skip-to-main:focus:not(:focus-visible) {
    outline: none;
  }

  .skip-to-main:focus-visible {
    transform: translateY(0);
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
{% endstylesheet %}
