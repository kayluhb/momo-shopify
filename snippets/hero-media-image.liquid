{% doc %}
  Renders a parallax hero background image.

  @param {image} image - Hero image
  @param {string} alt - Alt text for the image
  @param {string} [loading] - lazy or eager
  @param {string} [fetchpriority] - high when set for LCP images
{% enddoc %}

{% liquid
  assign hero_loading = loading | default: 'eager'
  assign hero_widths = '550, 720, 990, 1100, 1500, 2200, 3000, 3840'
%}

<div class="hero__parallax" data-hero-parallax-media>
  {% if fetchpriority != blank %}
    {{
      image
      | image_url: width: 3840
      | image_tag:
        widths: hero_widths,
        sizes: '100vw',
        loading: hero_loading,
        fetchpriority: fetchpriority,
        class: 'hero__img hero__img--parallax',
        alt: alt
    }}
  {% else %}
    {{
      image
      | image_url: width: 3840
      | image_tag:
        widths: hero_widths,
        sizes: '100vw',
        loading: hero_loading,
        class: 'hero__img hero__img--parallax',
        alt: alt
    }}
  {% endif %}
</div>

{% stylesheet %}
  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero .hero__media {
    top: -1px;
    height: calc(100% + 1px);
  }

  .hero__parallax {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero__img {
    position: relative;
    z-index: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
  }

  :where(.hero--parallax, .collection-hero--parallax) .hero__img--parallax {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 118%;
    max-width: none;
    object-fit: cover;
    object-position: center;
    transform: translate3d(0, calc(-50% + var(--hero-parallax-y, 0px)), 0);
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    :where(.hero--parallax, .collection-hero--parallax) .hero__img--parallax {
      position: relative;
      top: auto;
      left: auto;
      height: 100%;
      transform: none;
      will-change: auto;
    }
  }
{% endstylesheet %}
