<cart-drawer-component
  class="cart-drawer"
  {% if settings.cart_drawer_auto_open %}
    auto-open
  {% endif %}
>
  <button
    type="button"
    class="cart-drawer__trigger sr-only"
    aria-hidden="true"
    tabindex="-1"
    ref="trigger"
  ></button>

  <dialog
    ref="dialog"
    class="cart-drawer__dialog dialog-drawer"
    aria-labelledby="cart-drawer-heading"
  >
    <div class="cart-drawer__inner" data-hydration-key="cart-drawer-inner">
      <header class="cart-drawer__header">
        <h2 id="cart-drawer-heading" class="cart-drawer__heading">
          {{ 'cart.drawer_title' | t }}
        </h2>
        <button
          type="button"
          class="dialog-drawer__close cart-drawer__close focus-ring-brand"
          on:click="cart-drawer-component/close"
          aria-label="{{ 'cart.drawer_close' | t }}"
        >
          <span class="dialog-drawer__close-icon" aria-hidden="true">{{ 'icon-close.svg' | inline_asset_content }}</span>
        </button>
      </header>

      <div class="cart-drawer__content">
        {% render 'cart-line-items', section_id: section.id %}
      </div>

      {% unless cart.empty? %}
        <footer class="cart-drawer__footer">
          <a class="cart-drawer__view-cart focus-ring-brand" href="{{ routes.cart_url }}">
            {{ 'cart.view_cart' | t }}
          </a>
          <form action="{{ routes.cart_url }}" method="post">
            <button type="submit" name="checkout" class="focus-ring-brand">
              {{ 'cart.checkout' | t }}
            </button>
          </form>
        </footer>
      {% endunless %}
    </div>
  </dialog>
</cart-drawer-component>

{% stylesheet %}
  .cart-drawer__dialog {
    --animation-speed: 350ms;
    --animation-easing: cubic-bezier(0.4, 0, 0.2, 1);
    --dialog-drawer-opening-animation: cart-drawer-slide;
    --dialog-drawer-closing-animation: cart-drawer-slide;

    position: fixed;
    inset: 0 0 0 auto;
    width: var(--drawer-width);
    max-width: 100%;
    height: 100%;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    border: none;
    background: #fff;
    color: var(--color-brand-steel);
    box-shadow: -4px 0 24px rgb(0 0 0 / 12%);
  }

  .cart-drawer__dialog[open] {
    --start-x: 100%;
    --end-x: 0;

    animation: var(--dialog-drawer-opening-animation) var(--animation-speed) var(--animation-easing) forwards;
  }

  .cart-drawer__dialog[open].dialog-closing {
    --start-x: 0;
    --end-x: 100%;

    animation: var(--dialog-drawer-closing-animation) var(--animation-speed) var(--animation-easing) forwards;
  }

  .cart-drawer__dialog::backdrop {
    background: rgb(0 37 63 / 40%);
  }

  .cart-drawer__dialog[open]::backdrop {
    animation: cart-drawer-backdrop-in var(--animation-speed) var(--animation-easing) forwards;
  }

  .cart-drawer__dialog[open].dialog-closing::backdrop {
    animation: cart-drawer-backdrop-out var(--animation-speed) var(--animation-easing) forwards;
  }

  @keyframes cart-drawer-slide {
    from {
      transform: translateX(var(--start-x, 100%));
    }

    to {
      transform: translateX(var(--end-x, 0));
    }
  }

  @keyframes cart-drawer-backdrop-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes cart-drawer-backdrop-out {
    from {
      opacity: 1;
    }

    to {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cart-drawer__dialog[open],
    .cart-drawer__dialog[open].dialog-closing,
    .cart-drawer__dialog[open]::backdrop,
    .cart-drawer__dialog[open].dialog-closing::backdrop {
      animation: none;
    }
  }

  .cart-drawer__inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    padding: 1.25rem;
    box-sizing: border-box;
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cart-drawer__heading {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 700;
  }

  .cart-drawer__content {
    flex: 1;
    overflow: auto;
  }

  .cart-drawer__footer {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgb(0 37 63 / 12%);
  }

  .cart-drawer__footer button,
  .cart-drawer__view-cart {
    display: block;
    width: 100%;
    padding: 0.75rem 1rem;
    text-align: center;
    text-decoration: none;
  }

  .cart-drawer__footer button {
    border-radius: var(--style-border-radius);
    border: none;
    background: var(--color-brand-steel);
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-weight: 600;
  }

  .cart-items {
    width: 100%;
    border-collapse: collapse;
  }

  .cart-items th,
  .cart-items td {
    padding: 0.5rem 0.25rem;
    vertical-align: top;
    text-align: left;
  }

  .cart-items__product {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .cart-items__variant {
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    opacity: 0.8;
  }

  .cart-items__quantity input {
    width: 4rem;
  }

  .cart-items__subtotal {
    margin: 1rem 0 0;
    font-weight: 700;
  }

  .cart-items__remove-button {
    padding: 0;
    border: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    font: inherit;
    text-decoration: underline;
  }

  .cart-items__remove-button[aria-busy='true'] {
    cursor: wait;
    opacity: 0.65;
    text-decoration: none;
  }

  .cart-empty-state {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cart-empty {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart_drawer",
  "settings": []
}
{% endschema %}
