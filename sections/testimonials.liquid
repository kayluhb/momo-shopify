{% capture section_bg %}{% render 'section-color-scheme', scheme: section.settings.color_scheme %}{% endcapture %}

<section
  id="shopify-section-{{ section.id }}"
  class="testimonials full-width section-padding {{ section_bg }}"
>
  <div class="section-inner">
    {% render 'section-heading',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading,
      alignment: section.settings.heading_alignment
    %}

    {% if section.blocks.size > 0 %}
      <ul class="testimonials__grid list-none p-0" role="list">
        {% for block in section.blocks %}
          <li {{ block.shopify_attributes }}>
            <figure class="testimonials__card">
              {% if block.settings.rating > 0 %}
                <div class="testimonials__stars" aria-label="{{ 'sections.testimonials.rating_label' | t: rating: block.settings.rating }}">
                  {% for i in (1..5) %}
                    <span class="testimonials__star{% if i <= block.settings.rating %} testimonials__star--filled{% endif %}" aria-hidden="true">★</span>
                  {% endfor %}
                </div>
              {% endif %}

              {% if block.settings.quote != blank %}
                <blockquote class="testimonials__quote">
                  <p>{{ block.settings.quote | escape }}</p>
                </blockquote>
              {% endif %}

              <figcaption class="testimonials__author">
                {% if block.settings.avatar != blank %}
                  <div class="testimonials__avatar">
                    {{
                      block.settings.avatar
                      | image_url: width: 80
                      | image_tag: loading: 'lazy', widths: '40,80', alt: block.settings.author
                    }}
                  </div>
                {% endif %}
                <div class="testimonials__meta">
                  {% if block.settings.author != blank %}
                    <cite class="testimonials__name">{{ block.settings.author | escape }}</cite>
                  {% endif %}
                  {% if block.settings.role != blank %}
                    <span class="testimonials__role">{{ block.settings.role | escape }}</span>
                  {% endif %}
                </div>
              </figcaption>
            </figure>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .testimonials__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 750px) {
    .testimonials__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 990px) {
    .testimonials__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .testimonials__card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    margin: 0;
    padding: 1.5rem;
    border: 1px solid color-mix(in srgb, currentColor 15%, transparent);
    border-top: 3px solid var(--color-brand-rust);
    border-radius: var(--style-border-radius);
    background: color-mix(in srgb, var(--color-brand-canvas) 55%, transparent);
  }

  .testimonials__stars {
    display: flex;
    gap: 0.15rem;
    font-size: 0.875rem;
    line-height: 1;
  }

  .testimonials__star {
    color: color-mix(in srgb, currentColor 25%, transparent);
  }

  .testimonials__star--filled {
    color: var(--color-brand-warmth);
  }

  .testimonials__quote {
    margin: 0;
    flex: 1;
  }

  .testimonials__quote p {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
  }

  .testimonials__avatar {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    overflow: hidden;
    border-radius: 50%;
  }

  .testimonials__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonials__meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .testimonials__name {
    font-style: normal;
    font-size: 0.875rem;
  }

  .testimonials__role {
    font-size: 0.8125rem;
    opacity: 0.75;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "t:sections.shared.appearance_header"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme_label",
      "default": "white",
      "options": [
        { "value": "white", "label": "t:options.color_scheme.white" },
        { "value": "canvas", "label": "t:options.color_scheme.canvas" },
        { "value": "earth", "label": "t:options.color_scheme.earth" },
        { "value": "steel", "label": "t:options.color_scheme.steel" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.shared.content_header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.shared.eyebrow_label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.shared.heading_label",
      "default": "What customers say"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.shared.subheading_label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.shared.heading_alignment_label",
      "default": "center",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonials.blocks.testimonial.name",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "t:sections.testimonials.blocks.testimonial.rating_label",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:sections.testimonials.blocks.testimonial.quote_label",
          "default": "Beautiful craftsmanship and thoughtful design in every detail."
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "t:sections.testimonials.blocks.testimonial.avatar_label"
        },
        {
          "type": "text",
          "id": "author",
          "label": "t:sections.testimonials.blocks.testimonial.author_label",
          "default": "Customer name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "t:sections.testimonials.blocks.testimonial.role_label",
          "default": "Verified buyer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.presets.default_name",
      "settings": {
        "heading": "What customers say",
        "heading_alignment": "center",
        "color_scheme": "white",
      },
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Beautiful craftsmanship and thoughtful design in every detail.",
            "author": "Alex M.",
            "role": "Verified buyer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "The sculptural forms feel timeless — exactly what I was looking for.",
            "author": "Jordan K.",
            "role": "Verified buyer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Elevated my space instantly. Quality you can see and feel.",
            "author": "Sam R.",
            "role": "Verified buyer"
          }
        }
      ]
    }
  ]
}
{% endschema %}
