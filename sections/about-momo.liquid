{% liquid
  assign image_position = section.settings.image_position
  assign show_values = section.settings.show_brand_values
  assign image_alt = section.settings.image.alt | default: section.settings.heading
%}
{% capture section_bg %}{% render 'section-color-scheme', scheme: section.settings.color_scheme %}{% endcapture %}

<section
  id="shopify-section-{{ section.id }}"
  class="about-momo full-width py-14 md:py-20 {{ section_bg }}"
  {{ section.shopify_attributes }}
>
  <div class="section-inner about-momo__inner about-momo__inner--image-{{ image_position }}">
    <div class="about-momo__media">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 990px) 42vw, 100vw',
            widths: '600,900,1200,1400',
            class: 'about-momo__img',
            alt: image_alt
        }}
      {% else %}
        <div class="about-momo__mark" aria-hidden="true">
          <span class="about-momo__mark-svg">{{ 'logo.svg' | inline_asset_content }}</span>
        </div>
      {% endif %}
    </div>

    <div class="about-momo__content">
      {% if section.settings.eyebrow != blank %}
        <p class="about-momo__eyebrow type-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="about-momo__heading font-display">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="about-momo__text rte">{{ section.settings.text }}</div>
      {% endif %}

      {% if show_values %}
        <ul class="about-momo__values" aria-label="{{ 'sections.about_momo.values_label' | t }}">
          <li>{{ 'sections.about_momo.values.family' | t }}</li>
          <li>{{ 'sections.about_momo.values.heritage' | t }}</li>
          <li>{{ 'sections.about_momo.values.legacy' | t }}</li>
          <li>{{ 'sections.about_momo.values.fellowship' | t }}</li>
          <li>{{ 'sections.about_momo.values.warmth' | t }}</li>
          <li>{{ 'sections.about_momo.values.integrity' | t }}</li>
        </ul>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <div class="about-momo__cta">
          {% render 'button',
            label: section.settings.button_label,
            url: section.settings.button_link,
            style: section.settings.button_style
          %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .about-momo__inner {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 990px) {
    .about-momo__inner {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      gap: clamp(2.5rem, 5vw, 5rem);
    }

    .about-momo__inner--image-right .about-momo__media {
      order: 2;
    }
  }

  .about-momo__media {
    position: relative;
    overflow: hidden;
    border-radius: 0.25rem;
    aspect-ratio: 4 / 5;
    background-color: color-mix(in srgb, currentColor 6%, transparent);
  }

  .about-momo__media::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    z-index: 1;
    width: 0.25rem;
    background-color: var(--color-brand-rust, #c57639);
  }

  .about-momo__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-momo__mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 2.5rem;
    background-color: color-mix(in srgb, var(--color-brand-steel, #00253f) 4%, transparent);
  }

  .about-momo__mark-svg {
    display: block;
    width: min(12rem, 55%);
    margin-inline: auto;
    color: var(--color-brand-steel, #00253f);
  }

  .about-momo__mark-svg :where(svg) {
    width: 100%;
    height: auto;
  }

  .bg-brand-steel .about-momo__mark-svg,
  .bg-brand-earth .about-momo__mark-svg {
    color: currentColor;
    opacity: 0.35;
  }

  .about-momo__content {
    position: relative;
    padding-inline-start: 1rem;
    border-inline-start: 1px solid color-mix(in srgb, currentColor 12%, transparent);
  }

  @media (min-width: 990px) {
    .about-momo__content {
      padding-inline-start: 1.5rem;
    }
  }

  .about-momo__eyebrow {
    margin: 0 0 0.75rem;
  }

  .about-momo__heading {
    margin: 0 0 1.25rem;
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    line-height: 1.05;
  }

  .about-momo__text {
    font-size: 1.0625rem;
    line-height: 1.7;
    max-width: 36rem;
  }

  .about-momo__text :where(p) {
    margin: 0 0 1rem;
  }

  .about-momo__text :where(p:last-child) {
    margin-bottom: 0;
  }

  .about-momo__values {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    margin: 1.75rem 0 0;
    padding: 0;
    list-style: none;
  }

  .about-momo__values li {
    font-family: var(--font-brand--family, var(--font-display--family));
    font-size: 0.6875rem;
    font-weight: var(--font-weight-bold, 700);
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-brand-rust, #c57639);
  }

  .bg-brand-earth .about-momo__values li,
  .bg-brand-steel .about-momo__values li {
    color: var(--color-brand-warmth, #ea7657);
  }

  .about-momo__cta {
    margin-top: 1.75rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.about_momo.name",
  "tag": "section",
  "class": "about-momo-section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.about_momo.image_label",
      "info": "t:sections.about_momo.image_info"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.about_momo.image_position_label",
      "default": "left",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "right", "label": "t:options.alignment.right" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.shared.content_header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.shared.eyebrow_label",
      "default": "t:sections.about_momo.presets.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.shared.heading_label",
      "default": "t:sections.about_momo.presets.heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.shared.text_label",
      "default": "t:sections.about_momo.presets.text"
    },
    {
      "type": "checkbox",
      "id": "show_brand_values",
      "label": "t:sections.about_momo.show_values_label",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.shared.button_label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.shared.button_link_label"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:sections.shared.button_style_label",
      "default": "secondary",
      "options": [
        { "value": "primary", "label": "t:options.button_style.primary" },
        { "value": "secondary", "label": "t:options.button_style.secondary" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.shared.appearance_header"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme_label",
      "default": "canvas",
      "options": [
        { "value": "white", "label": "t:options.color_scheme.white" },
        { "value": "canvas", "label": "t:options.color_scheme.canvas" },
        { "value": "earth", "label": "t:options.color_scheme.earth" },
        { "value": "steel", "label": "t:options.color_scheme.steel" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.about_momo.presets.default_name",
      "settings": {
        "eyebrow": "About Momo",
        "heading": "Named for the heart of our home",
        "text": "<p>Momo is our founder's grandmother — the woman whose table brought everyone together. Her spirit of warmth, fellowship, and legacy is woven into everything we make.</p><p>We bridge the vibrant heritage of modern Mexico with the clean, functional silhouettes of mid-century design — crafting the backdrop for the moments you share around your hearth.</p>",
        "show_brand_values": true,
        "image_position": "left",
        "color_scheme": "canvas"
      }
    }
  ]
}
{% endschema %}
