{% liquid
  assign is_homepage = false
  if request.page_type == 'index'
    assign is_homepage = true
  endif

  assign header_text_color = section.settings.text_color | default: 'steel'
  assign header_classes = 'site-header full-width z-50 flex w-full min-h-0 justify-center [&_a]:text-inherit [&_svg]:text-inherit'
%}

<header
  class="{{ header_classes }} {% if is_homepage %}{% render 'brand-text-color-class', color: header_text_color %}{% endif %}"
  data-site-header
  data-section-id="{{ section.id }}"
  {% if is_homepage %}
    data-site-header-scroll
  {% endif %}
>
  <div class="site-header__inner flex min-h-0 w-full flex-nowrap items-center gap-4">
    <button
      type="button"
      class="site-header__icon-btn site-header__menu-trigger"
      data-menu-drawer-open
      aria-label="{{ 'sections.header.menu_open' | t }}"
    >
      <span class="site-header__icon-svg" aria-hidden="true">{{ 'icon-menu.svg' | inline_asset_content }}</span>
    </button>

    <nav
      class="site-header__nav site-header__nav--desktop flex min-h-0 min-w-0 flex-1 flex-nowrap items-center justify-start gap-4 text-sm [&_a]:relative [&_a]:inline-flex [&_a]:items-center [&_a]:justify-center [&_a]:font-bold [&_a]:no-underline [&_a]:hover:text-brand-rust"
      aria-label="{{ 'sections.header.main_navigation' | t }}"
    >
      {% for link in section.settings.menu.links %}
        <a
          href="{{ link.url }}"
          {% if link.active %}
            aria-current="page"
          {% endif %}
        >
          {{ link.title }}
        </a>
      {% endfor %}
    </nav>

    <a
      class="site-header__logo relative inline-flex min-h-0 shrink-0 items-center justify-center no-underline hover:text-brand-rust"
      href="{{ routes.root_url }}"
    >
      {% if settings.logo %}
        {{
          settings.logo
          | image_url: width: 400
          | image_tag: alt: shop.name, class: 'site-header__logo-mark object-contain'
        }}
      {% else %}
        <span class="sr-only">{{ shop.name }}</span>
        <span class="site-header__logo-mark">{{ 'logo.svg' | inline_asset_content }}</span>
      {% endif %}
    </a>

    <div class="site-header__utilities flex min-h-0 min-w-0 flex-1 items-center justify-end gap-4 text-sm">
      {% if shop.customer_accounts_enabled %}
        <shopify-store
          store-domain="{{ shop.secure_url }}"
          country="{{ localization.country.iso_code }}"
          language="{{ localization.language.iso_code }}"
        >
          <shopify-account menu="{{ section.settings.customer_account_menu }}">
            <span slot="signed-out-avatar" class="site-header__account-trigger">
              {{ 'icon-account.svg' | inline_asset_content }}
            </span>
          </shopify-account>
        </shopify-store>
      {% endif %}

      <button
        type="button"
        class="site-header__icon-btn site-header__cart-trigger"
        data-cart-drawer-open
        aria-label="{% if cart.item_count == 0 %}{{ 'cart.drawer_title' | t }}{% elsif cart.item_count == 1 %}{{ 'cart.drawer_title_one' | t }}{% else %}{{ 'cart.drawer_title_with_count' | t: count: cart.item_count }}{% endif %}"
      >
        <span class="site-header__icon-svg" aria-hidden="true">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        <span
          class="site-header__cart-count"
          data-header-cart-count
          {% if cart.item_count == 0 %}
            hidden
          {% endif %}
        >
          <span class="site-header__cart-count-bubble" data-header-cart-count-value aria-hidden="true">
            {{- cart.item_count -}}
          </span>
        </span>
      </button>
    </div>
  </div>

  <menu-drawer-component class="menu-drawer">
    <dialog
      ref="dialog"
      class="menu-drawer__dialog dialog-drawer"
      aria-labelledby="menu-drawer-heading"
    >
      <div class="menu-drawer__inner">
        <header class="menu-drawer__header">
          <h2 id="menu-drawer-heading" class="menu-drawer__heading">
            {{ 'sections.header.menu_drawer_title' | t }}
          </h2>
          <button
            type="button"
            class="dialog-drawer__close menu-drawer__close"
            on:click="menu-drawer-component/close"
            aria-label="{{ 'sections.header.menu_close' | t }}"
          >
            <span class="dialog-drawer__close-icon" aria-hidden="true">{{ 'icon-close.svg' | inline_asset_content }}</span>
          </button>
        </header>

        <nav class="menu-drawer__nav" aria-label="{{ 'sections.header.main_navigation' | t }}">
          <ul class="menu-drawer__list">
            {% for link in section.settings.menu.links %}
              <li class="menu-drawer__item">
                <a
                  class="menu-drawer__link"
                  href="{{ link.url }}"
                  on:click="menu-drawer-component/close"
                  {% if link.active %}
                    aria-current="page"
                  {% endif %}
                >
                  {{ link.title }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      </div>
    </dialog>
  </menu-drawer-component>
</header>

{% style %}
  /* Shopify section groups have no wrapper — only this section is sticky. */
  .shopify-section.header-section {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    margin: 0;
    padding: 0;
    background: transparent;
    align-self: flex-start;
  }

  .template-index main {
    margin-top: calc(-1 * var(--header-height));
  }

  .site-header {
    box-sizing: border-box;
    padding-block: var(--header-padding-y-scrolled);
    background-color: #fff;
    color: var(--color-brand-steel);
  }

  .template-index [data-site-header-scroll] {
    padding-block: calc(
      var(--header-padding-y) + (var(--header-padding-y-scrolled) - var(--header-padding-y)) *
        var(--header-scroll-progress)
    );
    background-color: color-mix(in srgb, transparent, #fff calc(var(--header-scroll-progress) * 100%));
    color: color-mix(in srgb, #fff, var(--color-brand-steel) calc(var(--header-scroll-progress) * 100%));
    transition: none;
  }

  .template-index [data-site-header-scroll] :where(a, button),
  .template-index [data-site-header-scroll] shopify-account::part(signed-out-avatar) {
    transition: none;
  }

  .template-index [data-site-header-scroll] .site-header__logo-mark {
    transition: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__logo-mark {
      transition: none;
    }
  }

  .site-header__inner {
    box-sizing: border-box;
    max-width: var(--page-width);
    padding-inline: var(--page-margin);
  }

  @media (max-width: 749px) {
    .site-header__inner {
      gap: 0.5rem;
      max-width: 100%;
      padding-inline: var(--page-margin-mobile);
    }

    .site-header__menu-trigger {
      margin-inline-end: 1rem;
    }
  }

  .site-header__logo-mark {
    display: block;
    max-height: var(--header-logo-max-height-scrolled);
    width: auto;
    max-width: min(12rem, 40vw);
  }

  .template-index [data-site-header-scroll] .site-header__logo-mark {
    max-height: calc(
      var(--header-logo-max-height) + (var(--header-logo-max-height-scrolled) - var(--header-logo-max-height)) *
        var(--header-scroll-progress)
    );
  }

  .site-header__logo-mark :where(img, svg) {
    display: block;
    width: auto;
    max-width: min(12rem, 40vw);
    height: auto;
    max-height: inherit;
  }

  .site-header__icon-btn,
  .site-header__utilities shopify-account {
    position: relative;
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: var(--header-icon-size-scrolled);
    height: var(--header-icon-size-scrolled);
    line-height: 0;
    color: inherit;
    transform: none;
    backface-visibility: hidden;
    transition: none;
  }

  .template-index [data-site-header-scroll] .site-header__icon-btn,
  .template-index [data-site-header-scroll] .site-header__utilities shopify-account {
    width: calc(
      var(--header-icon-size) + (var(--header-icon-size-scrolled) - var(--header-icon-size)) *
        var(--header-scroll-progress)
    );
    height: calc(
      var(--header-icon-size) + (var(--header-icon-size-scrolled) - var(--header-icon-size)) *
        var(--header-scroll-progress)
    );
  }

  .site-header__icon-btn {
    border: none;
    background: transparent;
    cursor: pointer;
    font: inherit;
    text-decoration: none;
  }

  .site-header__icon-btn:hover {
    color: var(--color-brand-rust);
  }

  .site-header__icon-btn:focus-visible {
    outline: 2px solid var(--color-brand-rust);
    outline-offset: 2px;
  }

  .site-header__cart-trigger {
    overflow: visible;
  }

  .site-header__cart-count {
    position: absolute;
    top: -0.2rem;
    right: -0.35rem;
    z-index: 1;
    pointer-events: none;
  }

  .site-header__cart-count[hidden] {
    display: none;
  }

  .site-header__cart-count-bubble {
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    min-width: 1.125rem;
    height: 1.125rem;
    padding-inline: 0.3rem;
    border-radius: var(--style-border-radius);
    background-color: var(--color-brand-rust, #c57639);
    color: #fff;
    font-family: var(--font-brand--family, var(--font-display--family, sans-serif));
    font-size: 0.625rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.02em;
    box-shadow: 0 0 0 2px #fff;
  }

  .template-index [data-site-header-scroll] .site-header__cart-count-bubble {
    box-shadow: 0 0 0 2px color-mix(in srgb, #fff, transparent calc((1 - var(--header-scroll-progress)) * 100%));
  }

  .site-header__icon-svg {
    display: contents;
  }

  .site-header__icon-btn :where(svg),
  .site-header__account-trigger :where(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .site-header__utilities shopify-account {
    --shopify-account-avatar-size: var(--header-icon-size-scrolled);
    --shopify-account-signed-in-avatar-size: var(--header-icon-size-scrolled);
    --shopify-account-color-accent: currentcolor;
    --shopify-account-color-accent-hover: var(--color-brand-rust);
    --shopify-account-color-border: transparent;
  }

  .site-header__utilities shopify-account::part(signed-out-avatar) {
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    outline: none;
    box-shadow: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    transition: none;
  }

  .site-header__utilities shopify-account::part(signed-out-avatar):hover {
    color: var(--color-brand-rust);
  }

  .site-header__utilities shopify-account::part(signed-out-avatar):focus-visible {
    outline: 2px solid var(--color-brand-rust);
    outline-offset: 2px;
  }

  .site-header__account-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: inherit;
    pointer-events: none;
  }

  .template-index [data-site-header-scroll] .site-header__utilities shopify-account {
    --shopify-account-avatar-size: calc(
      var(--header-icon-size) + (var(--header-icon-size-scrolled) - var(--header-icon-size)) *
        var(--header-scroll-progress)
    );
    --shopify-account-signed-in-avatar-size: calc(
      var(--header-icon-size) + (var(--header-icon-size-scrolled) - var(--header-icon-size)) *
        var(--header-scroll-progress)
    );
  }

  .site-header__menu-trigger {
    display: none;
    flex-shrink: 0;
  }

  @media (max-width: 749px) {
    .site-header__menu-trigger {
      display: inline-flex;
    }

    .site-header__nav--desktop {
      display: none;
    }
  }

  .menu-drawer__dialog {
    --animation-speed: 350ms;
    --animation-easing: cubic-bezier(0.4, 0, 0.2, 1);
    --dialog-drawer-opening-animation: menu-drawer-slide;
    --dialog-drawer-closing-animation: menu-drawer-slide;

    position: fixed;
    inset: 0 auto 0 0;
    width: var(--drawer-width);
    max-width: 100%;
    height: 100%;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    border: none;
    background: #fff;
    color: var(--color-brand-steel, #00253f);
    box-shadow: 4px 0 24px rgb(0 0 0 / 12%);
  }

  .menu-drawer__dialog[open] {
    --start-x: -100%;
    --end-x: 0;

    animation: var(--dialog-drawer-opening-animation) var(--animation-speed) var(--animation-easing) forwards;
  }

  .menu-drawer__dialog[open].dialog-closing {
    --start-x: 0;
    --end-x: -100%;

    animation: var(--dialog-drawer-closing-animation) var(--animation-speed) var(--animation-easing) forwards;
  }

  .menu-drawer__dialog::backdrop {
    background: rgb(0 37 63 / 40%);
  }

  .menu-drawer__dialog[open]::backdrop {
    animation: menu-drawer-backdrop-in var(--animation-speed) var(--animation-easing) forwards;
  }

  .menu-drawer__dialog[open].dialog-closing::backdrop {
    animation: menu-drawer-backdrop-out var(--animation-speed) var(--animation-easing) forwards;
  }

  @keyframes menu-drawer-slide {
    from {
      transform: translateX(var(--start-x, -100%));
    }

    to {
      transform: translateX(var(--end-x, 0));
    }
  }

  @keyframes menu-drawer-backdrop-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes menu-drawer-backdrop-out {
    from {
      opacity: 1;
    }

    to {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-drawer__dialog[open],
    .menu-drawer__dialog[open].dialog-closing,
    .menu-drawer__dialog[open]::backdrop,
    .menu-drawer__dialog[open].dialog-closing::backdrop {
      animation: none;
    }
  }

  .menu-drawer__inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    height: 100%;
    padding: 1.25rem;
    box-sizing: border-box;
  }

  .menu-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .menu-drawer__heading {
    margin: 0;
    font-family: var(--font-brand--family, var(--font-display--family, sans-serif));
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .menu-drawer__link:focus-visible {
    outline: 2px solid var(--color-brand-rust);
    outline-offset: 2px;
  }

  .menu-drawer__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .menu-drawer__item + .menu-drawer__item {
    margin-top: 0.25rem;
  }

  .menu-drawer__link {
    display: block;
    padding: 0.75rem 0;
    color: inherit;
    font-family: var(--font-brand--family, var(--font-display--family, sans-serif));
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .menu-drawer__link:hover {
    color: var(--color-brand-rust);
  }

  .menu-drawer__link[aria-current='page'] {
    color: var(--color-brand-rust);
  }
{% endstyle %}

<script>
  (function () {
    var header = document.querySelector('[data-site-header]');
    if (!header) return;

    var usesScrollShrink = header.hasAttribute('data-site-header-scroll');

    function syncHeaderHeight() {
      var height = header.offsetHeight + 'px';
      document.documentElement.style.setProperty('--header-height', height);
      document.documentElement.style.setProperty('--header-height-scrolled', height);
    }

    syncHeaderHeight();
    window.addEventListener('resize', syncHeaderHeight, { passive: true });

    if (typeof ResizeObserver !== 'undefined' && !usesScrollShrink) {
      new ResizeObserver(syncHeaderHeight).observe(header);
    }
  })();
</script>

{% unless request.design_mode %}
  <script type="module">
    import { hydrate } from '@theme/section-hydration';
    hydrate('{{ section.id }}');
  </script>
{% endunless %}

{% javascript %}
  (function () {
    var header = document.querySelector('[data-site-header]');
    if (!header || !header.hasAttribute('data-site-header-scroll')) return;

    var root = document.documentElement;
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    var shrinkRange = parseFloat(getComputedStyle(root).getPropertyValue('--header-shrink-scroll-range')) || 96;
    var ticking = false;

    function getScrollY() {
      if (document.body.style.position === 'fixed' && document.body.style.top) {
        return Math.abs(parseFloat(document.body.style.top)) || 0;
      }

      return window.scrollY;
    }

    function setScrollProgress() {
      ticking = false;
      var scrollY = getScrollY();
      var progress;

      if (reduceMotion.matches) {
        progress = scrollY > 0 ? 1 : 0;
      } else {
        progress = Math.min(1, Math.max(0, scrollY / shrinkRange));
      }

      root.style.setProperty('--header-scroll-progress', String(progress));

      var height = header.offsetHeight + 'px';
      root.style.setProperty('--header-height', height);
      root.style.setProperty('--header-height-scrolled', height);
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(setScrollProgress);
      }
    }

    reduceMotion.addEventListener('change', setScrollProgress);
    document.addEventListener('dialog:open', setScrollProgress);
    document.addEventListener('dialog:close', setScrollProgress);
    setScrollProgress();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', setScrollProgress, { passive: true });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "class": "header-section",
  "settings": [
    {
      "type": "select",
      "id": "text_color",
      "label": "t:sections.header.settings.text_color_label",
      "default": "steel",
      "options": [
        {
          "value": "white",
          "label": "t:options.brand_color.white"
        },
        {
          "value": "steel",
          "label": "t:options.brand_color.steel"
        },
        {
          "value": "rust",
          "label": "t:options.brand_color.rust"
        },
        {
          "value": "earth",
          "label": "t:options.brand_color.earth"
        },
        {
          "value": "warmth",
          "label": "t:options.brand_color.warmth"
        },
        {
          "value": "heart",
          "label": "t:options.brand_color.heart"
        }
      ]
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
