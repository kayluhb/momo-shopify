{% doc %}
  Renders a styled link button.

  @param {string} label - Button label text
  @param {string} url - Destination URL
  @param {string} [style] - primary or secondary (default: primary)
  @param {string} [class] - Additional CSS classes

  @example
  {% render 'button', label: 'Shop all', url: routes.all_products_collection_url, style: 'primary' %}
{% enddoc %}

{% liquid
  assign button_style = style | default: 'primary'
  assign button_class = 'btn btn--' | append: button_style

  if class != blank
    assign button_class = button_class | append: ' ' | append: class
  endif
%}

<a class="{{ button_class }}" href="{{ url }}">
  {{ label | escape }}
</a>

{% stylesheet %}
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border: 2px solid transparent;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
  }

  .btn:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  .btn--primary {
    border-color: var(--color-brand-steel, #00253f);
    background-color: var(--color-brand-steel, #00253f);
    color: #fff;
  }

  .btn--primary:hover {
    border-color: var(--color-brand-rust, #c57639);
    background-color: var(--color-brand-rust, #c57639);
    color: #fff;
  }

  .btn--secondary {
    border-color: currentColor;
    background-color: transparent;
    color: inherit;
  }

  .btn--secondary:hover {
    opacity: 0.75;
  }
{% endstylesheet %}
