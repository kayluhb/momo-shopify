{% capture section_bg %}{% render 'section-color-scheme', scheme: section.settings.color_scheme %}{% endcapture %}

<section
  id="shopify-section-{{ section.id }}"
  class="bento-grid full-width py-14 md:py-20 {{ section_bg }}"
  style="
    --bento-gap: {{ section.settings.gap }}px;
    --bento-radius: {{ section.settings.corner_radius }}px;
    --bento-min-height: {{ section.settings.min_height }}px;
  "
>
  <div class="section-inner">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      {% render 'section-heading',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        subheading: section.settings.subheading,
        alignment: section.settings.heading_alignment
      %}
    {% endif %}

    <div class="bento-grid__grid" role="list">
      {% for block in section.blocks %}
      {% liquid
        assign tile_url = block.settings.link
        if tile_url == blank
          assign tile_url = '#'
        endif

        assign tile_overlay = block.settings.overlay_opacity
        if tile_overlay == blank
          assign tile_overlay = 25
        endif
      %}

      <a
        href="{{ tile_url }}"
        class="bento-grid__tile bento-grid__tile--{{ block.settings.layout }}{% if block.settings.eyebrow != blank and block.settings.layout == 'featured' %} bento-grid__tile--has-eyebrow{% endif %}"
        role="listitem"
        {{ block.shopify_attributes }}
      >
        <div class="bento-grid__media">
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 990px) 33vw, 100vw',
                widths: '400,600,800,1000,1200,1600',
                class: 'bento-grid__img',
                alt: block.settings.image.alt | default: block.settings.title
            }}
          {% else %}
            <div class="bento-grid__placeholder" aria-hidden="true">
              {{ 'collection-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <span
            class="bento-grid__overlay"
            style="--overlay: {{ tile_overlay | divided_by: 100.0 }}"
            aria-hidden="true"
          ></span>
        </div>

        <div class="bento-grid__content">
          {% if block.settings.eyebrow != blank %}
            <p class="bento-grid__eyebrow">{{ block.settings.eyebrow | escape }}</p>
          {% endif %}

          {% if block.settings.title != blank %}
            <p class="bento-grid__title">{{ block.settings.title | escape }}</p>
          {% endif %}
        </div>
      </a>
    {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .section-heading + .bento-grid__grid {
    margin-top: 2.5rem;
  }

  .bento-grid__grid {
    display: grid;
    gap: var(--bento-gap, 12px);
    grid-template-columns: 1fr;
    grid-auto-rows: minmax(220px, auto);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media (min-width: 750px) {
    .bento-grid__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      grid-template-rows: repeat(2, minmax(0, 1fr));
      min-height: var(--bento-min-height, 520px);
    }
  }

  .bento-grid__tile {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--bento-radius, 14px);
    color: #fff;
    text-decoration: none;
    isolation: isolate;
  }

  .bento-grid__tile:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  @media (min-width: 750px) {
    .bento-grid__tile {
      min-height: 0;
      height: 100%;
    }

    .bento-grid__tile--featured {
      grid-column: 1;
      grid-row: 1 / 3;
    }

    .bento-grid__tile--small-left,
    .bento-grid__tile--small-right {
      grid-row: 1;
    }

    .bento-grid__tile--small-left {
      grid-column: 2;
    }

    .bento-grid__tile--small-right {
      grid-column: 3;
    }

    .bento-grid__tile--wide {
      grid-column: 2 / 4;
      grid-row: 2;
    }
  }

  .bento-grid__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background-color: color-mix(in srgb, currentColor 10%, transparent);
  }

  .bento-grid__img,
  .bento-grid__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .bento-grid__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bento-grid__placeholder svg {
    width: 55%;
    opacity: 0.35;
  }

  .bento-grid__overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / var(--overlay, 0.25));
    transition: background-color 300ms ease;
  }

  .bento-grid__tile:hover .bento-grid__img,
  .bento-grid__tile:hover .bento-grid__placeholder {
    transform: scale(1.04);
  }

  .bento-grid__tile:hover .bento-grid__overlay {
    background: rgb(0 0 0 / calc(var(--overlay, 0.25) + 0.12));
  }

  .bento-grid__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 220px;
    height: 100%;
    padding: 1.25rem;
    pointer-events: none;
  }

  @media (min-width: 750px) {
    .bento-grid__content {
      min-height: 0;
      padding: 1.5rem;
    }
  }

  .bento-grid__tile--has-eyebrow .bento-grid__content {
    justify-content: space-between;
  }

  .bento-grid__eyebrow {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    line-height: 1.3;
    text-align: center;
    text-transform: uppercase;
  }

  @media (min-width: 750px) {
    .bento-grid__tile--featured .bento-grid__eyebrow {
      align-self: center;
      margin-block: auto;
    }
  }

  .bento-grid__title {
    margin: 0;
    font-family: var(--font-display--family, var(--font-primary--family));
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .bento-grid__tile--featured .bento-grid__title {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.bento_grid.name",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "t:sections.shared.content_header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.shared.eyebrow_label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.shared.heading_label"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.shared.subheading_label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.shared.heading_alignment_label",
      "default": "center",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.shared.appearance_header"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:sections.bento_grid.gap_label",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "t:sections.bento_grid.corner_radius_label",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "t:sections.bento_grid.min_height_label",
      "min": 400,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 520
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme_label",
      "default": "white",
      "options": [
        { "value": "white", "label": "t:options.color_scheme.white" },
        { "value": "canvas", "label": "t:options.color_scheme.canvas" },
        { "value": "earth", "label": "t:options.color_scheme.earth" },
        { "value": "steel", "label": "t:options.color_scheme.steel" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "t:sections.bento_grid.blocks.tile.name",
      "settings": [
        {
          "type": "select",
          "id": "layout",
          "label": "t:sections.bento_grid.blocks.tile.layout_label",
          "default": "small_left",
          "options": [
            { "value": "featured", "label": "t:sections.bento_grid.blocks.tile.layout_featured" },
            { "value": "small_left", "label": "t:sections.bento_grid.blocks.tile.layout_small_left" },
            { "value": "small_right", "label": "t:sections.bento_grid.blocks.tile.layout_small_right" },
            { "value": "wide", "label": "t:sections.bento_grid.blocks.tile.layout_wide" }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.bento_grid.blocks.tile.image_label"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "t:sections.shared.eyebrow_label",
          "info": "t:sections.bento_grid.blocks.tile.eyebrow_info"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.bento_grid.blocks.tile.title_label",
          "default": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.shared.link_url_label"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "t:sections.bento_grid.blocks.tile.overlay_opacity_label",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 25
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.bento_grid.presets.default_name",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "layout": "featured",
            "eyebrow": "Leather ear pads",
            "title": "MG20 gaming headphones",
            "link": "shopify://collections/all"
          }
        },
        {
          "type": "tile",
          "settings": {
            "layout": "small_left",
            "title": "MW08 sport",
            "link": "shopify://collections/all"
          }
        },
        {
          "type": "tile",
          "settings": {
            "layout": "small_right",
            "title": "Accessories",
            "link": "shopify://collections/all"
          }
        },
        {
          "type": "tile",
          "settings": {
            "layout": "wide",
            "title": "MH40 wireless",
            "link": "shopify://collections/all"
          }
        }
      ]
    }
  ]
}
{% endschema %}
