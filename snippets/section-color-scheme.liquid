{% doc %}
  Returns Tailwind classes for a section color scheme.

  @param {string} scheme - white, canvas, earth, rust, steel, warmth, or heart

  @example
  {% capture section_bg %}{% render 'section-color-scheme', scheme: section.settings.color_scheme %}{% endcapture %}
{% enddoc %}
{% liquid
  case scheme
    when 'earth'
      echo 'bg-brand-earth text-white'
    when 'rust'
      echo 'bg-brand-rust text-white'
    when 'steel'
      echo 'bg-brand-steel text-white'
    when 'warmth'
      echo 'bg-brand-warmth text-white'
    when 'heart'
      echo 'bg-brand-heart text-white'
    when 'canvas'
      echo 'bg-brand-canvas text-brand-steel'
    else
      echo 'bg-white text-brand-steel'
  endcase
%}
