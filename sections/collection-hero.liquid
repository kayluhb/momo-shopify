{% liquid
  assign hero_image = section.settings.image
  if hero_image == blank
    assign hero_image = collection.image
  endif

  assign hero_heading = section.settings.heading
  if hero_heading == blank
    assign hero_heading = collection.title
  endif

  assign hero_description = section.settings.description
  if hero_description == blank
    assign hero_description = collection.description
  endif

  assign overlay_opacity = section.settings.overlay_opacity
  if overlay_opacity == blank
    assign overlay_opacity = 40
  endif

  if hero_image != blank
    if hero_image.alt != blank
      assign hero_alt = hero_image.alt
    else
      assign hero_alt = hero_heading
    endif
  endif
%}

<div
  id="CollectionHero-{{ section.id }}"
  class="collection-hero hero hero--parallax full-width"
  data-hero-parallax
  data-collection-hero
  {{ section.shopify_attributes }}
>
  <div class="collection-hero__media hero__media">
    {% if hero_image != blank %}
      <div class="hero__parallax" data-hero-parallax-media>
        {{
          hero_image
          | image_url: width: 3840
          | image_tag:
            widths: '550, 720, 990, 1100, 1500, 2200, 3000, 3840',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'hero__img hero__img--parallax',
            alt: hero_alt
        }}
      </div>
    {% else %}
      <div class="collection-hero__placeholder" aria-hidden="true">
        {{ 'collection-1' | placeholder_svg_tag: class: 'hero__img hero__img--placeholder' }}
      </div>
    {% endif %}
    <div
      class="hero__overlay"
      style="background: rgb(0 0 0 / {{ overlay_opacity }}%);"
      aria-hidden="true"
    ></div>
  </div>

  <div class="collection-hero__content">
    <h1 class="collection-hero__heading">{{ hero_heading | escape }}</h1>
    {% if hero_description != blank %}
      <div class="collection-hero__description rte">
        {{ hero_description }}
      </div>
    {% endif %}
  </div>
</div>

{% style %}
  #CollectionHero-{{ section.id }} {
    height: {{ section.settings.hero_height }}rem;
  }
{% endstyle %}

{% stylesheet %}
  .collection-hero {
    position: relative;
    height: 18rem;
    overflow: hidden;
  }

  .collection-hero .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .collection-hero__placeholder {
    position: absolute;
    inset: 0;
    background: rgb(30 30 30);
  }

  .collection-hero__placeholder .hero__img--placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
  }

  .collection-hero .hero__parallax {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .collection-hero .hero__img {
    position: relative;
    z-index: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
  }

  .collection-hero.hero--parallax .hero__img--parallax {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 118%;
    max-width: none;
    object-fit: cover;
    object-position: center;
    transform: translate3d(0, calc(-50% + var(--hero-parallax-y, 0px)), 0);
    will-change: transform;
  }

  .collection-hero__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    width: 100%;
    max-width: min(calc(var(--page-width) - var(--page-margin) * 2), calc(100% - var(--page-margin) * 2));
    margin-inline: auto;
    padding: 1.5rem var(--page-margin);
    color: #fff;
    pointer-events: none;
  }

  .collection-hero__content .rte a {
    pointer-events: auto;
  }

  .collection-hero__heading {
    margin: 0 0 0.5rem;
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    line-height: 1.1;
    font-weight: 700;
  }

  .collection-hero__description {
    margin: 0;
    max-width: 36rem;
    font-size: clamp(0.875rem, 0.35vw + 0.8rem, 1rem);
    line-height: 1.5;
    color: rgb(255 255 255 / 88%);
  }

  .collection-hero__description p {
    margin: 0;
  }

  .collection-hero__description p + p {
    margin-top: 0.5rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-hero.hero--parallax .hero__img--parallax {
      position: relative;
      top: auto;
      left: auto;
      height: 100%;
      transform: none;
      will-change: auto;
    }
  }
{% endstylesheet %}

{% render 'hero-parallax' %}

{% schema %}
{
  "name": "t:sections.collection_hero.name",
  "tag": "section",
  "class": "section-collection-hero",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.collection_hero.settings.image_label",
      "info": "t:sections.collection_hero.settings.image_info"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "t:sections.collection_hero.settings.overlay_opacity_label",
      "default": 40
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 14,
      "max": 28,
      "step": 2,
      "unit": "rem",
      "label": "t:sections.collection_hero.settings.hero_height_label",
      "default": 18
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collection_hero.settings.heading_label",
      "info": "t:sections.collection_hero.settings.heading_info"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.collection_hero.settings.description_label",
      "info": "t:sections.collection_hero.settings.description_info"
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection_hero.presets.default_name"
    }
  ]
}
{% endschema %}
